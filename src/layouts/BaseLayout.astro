---
import SchemasSERP from "@/components/global/SchemasSERP.astro";
import Footer from "@/components/home/Footer.astro";
import Head from "@/components/home/Head.astro";
import Header from "@/components/home/Header.astro";
import { getLangFromUrl } from "@/i18n/utils";

//Mientras no se editan los otros estilos se importa los estilos globales
//Se considera cambiar los estilos
import '@/styles/global.css';

const lang = getLangFromUrl(Astro.url);
const { seo, offI18n } = Astro.props;
---

<!doctype html>
<html lang={lang}>
    <head>
        <Head offI18n={offI18n} {...seo} />
        <SchemasSERP />
        <meta charset="utf-8" />
        <slot name="schema-jsonld" />
    </head>
    <body id="body">
        <!-- Google Tag Manager-->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NV35K8DZ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <Header offI18n={offI18n} />
        <main>
            <slot />
        </main>
        <!-- <Footer /> -->
    </body>
</html>
