---
import { getI18N } from "@/i18n";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@/i18n/utils";
import { Facebook, Instagram, Tripadvaisor } from "@/icons/allIcons";
import { Logo_blanco } from "@/icons/allIcons";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const lang = getLangFromUrl(Astro.url);
const k = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentYear = new Date().getFullYear();
const navFooter = [
  {
    title: k("nav.home"),
    link: translatePath("/"),
  },
  {
    title: "Blog",
    link: "/blog/",
  },
  {
    title: k("nav.cenoteTrail"),
    link: translatePath("/cenote-trail/"),
  },
  {
    title: k("nav.about"),
    link: translatePath("/about/"),
  },
  {
    title: k("nav.contact"),
    link: translatePath("/Contact/contact/"),
  },
];

import {
  Phone,
  Mail,
  Tripadvisor,
  Accessibility,
} from "lucide-react";

const socialMedia = [
  {
    title: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_FACEBOOK,
    icon: Facebook,
    link: "https://www.facebook.com/cenoteadventuring/",
  },
  {
    litle: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_FACEBOOK,
    icon: Instagram,
    link: "https://www.instagram.com/cenoteadventuring/",
  },
];
---

<footer
  class="bg-[#006083] text-white py-16 px-8 mt-auto w-full border-t border-white/10"
>
  <div
    class="max-w-[1800px] mx-auto lg:max-w-8xl grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-24"
  >
    <div class="flex flex-col gap-6">
      <h3
        class="font-serif text-xl md:text-3xl lg:text-xl tracking-[0.2em] uppercase border-b border-white/10 pb-4 w-fit"
      >
        Contact Us
      </h3>

      <div class="space-y-4 md:space-y-6 w-full">
        {/* Teléfono */}
        <div
          class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300"
        >
          <div
            class="bg-white text-[#006083] p-2.5 md:p-4 rounded-full shadow-lg shrink-0"
          >
            <Phone
              size={24}
              className="md:w-8 md:h-8 lg:w-5 lg:h-5"
              fill="currentColor"
              strokeWidth={0}
            />
          </div>
          <a
            href="tel:+529982998131"
            class="text-sm md:text-2xl lg:text-sm tracking-[0.15em] font-medium"
          >
            +52 9982 99 81 31
          </a>
        </div>

        {/* Emails */}
        <div
          class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300"
        >
          <div
            class="bg-white text-[#005B71] p-2.5 md:p-4 rounded-full shadow-lg shrink-0"
          >
            <Mail
              size={24}
              className="md:w-8 md:h-8 lg:w-5 lg:h-5"
              fill="currentColor"
              strokeWidth={0}
            />
          </div>
          <div class="flex flex-col gap-1">
            <span
              class="text-[9px] md:text-lg lg:text-[9px] uppercase opacity-60 tracking-[0.2em]"
              >For reservations:</span
            >
            <a
              href="mailto:reservas@grupo-extreme.com"
              class="text-xs md:text-2xl lg:text-xs hover:underline underline-offset-4"
              >reservas@grupo-extreme.com</a
            >
          </div>
        </div>

        <div
          class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300"
        >
          <div
            class="bg-white text-[#006083] p-2.5 md:p-4 rounded-full shadow-lg shrink-0"
          >
            <Mail
              size={24}
              className="md:w-8 md:h-8 lg:w-5 lg:h-5"
              fill="currentColor"
              strokeWidth={0}
            />
          </div>
          <div class="flex flex-col gap-1">
            <span
              class="text-[9px] md:text-lg lg:text-[9px] uppercase opacity-60 tracking-[0.2em]"
              >For corporate inquiries:</span
            >
            <a
              href="mailto:info@extremeadventuringcancun.com"
              class="text-xs md:text-2xl lg:text-xs hover:underline underline-offset-4"
              >info@extremeadventuringcancun.com</a
            >
          </div>
        </div>
      </div>
    </div>

    <div
      class="relative flex flex-row flex-wrap items-start justify-between gap-6 w-full max-w-screen-2xl mx-auto px-4"
    >
      <div class="flex flex-col gap-4 w-[45%] lg:w-auto">
        <h3
          class="font-serif text-sm md:text-3xl lg:text-xl tracking-[0.1em] uppercase border-b border-white/10 pb-2 w-fit"
        >
          About
        </h3>
        <nav class="mt-4 md:mt-8">
          <ul
            class="flex flex-col gap-3 md:gap-5 text-[9px] md:text-2xl lg:text-[11px] uppercase tracking-[0.2em] font-light"
          >
            {
              navFooter.map((item) => (
                <li>
                  <a
                    href={item.link}
                    class="hover:opacity-60 transition-opacity"
                  >
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <div class="flex flex-col gap-4 items-end items-start w-[45%] w-auto">
        <h3
          class="font-serif text-sm md:text-3xl lg:text-xl tracking-[0.1em] uppercase border-b border-white/10 pb-2 w-fit"
        >
          Follow Us                   
        </h3>
        <ul
          class="flex flex-col gap-4 md:gap-8 mt-4 md:mt-8 text-[9px] md:text-2xl lg:text-[11px] uppercase tracking-[0.1em] font-medium items-end lg:items-start"
        >
          <li>
            <a href="#" class="flex items-center gap-2 md:gap-4 group">
              <span class="order-1">Facebook</span>
              <Facebook
                size={16}
                className="md:w-8 md:h-8 lg:w-5 lg:h-5 group-hover:scale-110 transition-transform order-2"
              />
            </a>
          </li>
          <li>
            <a href="#" class="flex items-center gap-2 md:gap-4 group">
              <span class="order-1">Instagram</span>
              <Instagram
                size={16}
                className="md:w-8 md:h-8 lg:w-5 lg:h-5 group-hover:scale-110 transition-transform order-2"
              />
            </a>
          </li>
        </ul>
      </div>

      <Logo_blanco
        class="block mx-auto h-25 lg:h-35 w-auto p-4 -mt-5"
      />
    </div>

    <div
      class="pt-10 border-t border-white/10 flex flex-col lg:flex-row justify-between items-center lg:items-end -mt-14"
    >
      <div
        class="text-[9px] md:text-xl lg:text-[9px] uppercase tracking-[0.3em] text-white/50 text-center lg:text-left leading-loose order-2 lg:order-1"
      >
        <p>© {currentYear} Cenote Adventuring Cancun. All Rights Reserved.</p>
        <p class="mt-3 lg:mt-2 text-white/30">Design By Grupo Extreme</p>
      </div>

      <div
        class="flex flex-wrap justify-center lg:gap-10 text-[10px] md:text-xl lg:text-[9px] uppercase tracking-[0.3em] text-white/50 order-1 lg:order-2 font-medium"
      >
        <a
          href="#"
          class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1"
          >Privacy Policy</a
        >
        <a
          href="#"
          class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1"
          >Terms of Service</a
        >
        <a
          href="#"
          class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1"
          >Cookies Settings</a
        >
      </div>
    </div>
  </div>
</footer>
