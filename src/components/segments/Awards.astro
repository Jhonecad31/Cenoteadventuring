---
import { getI18N } from "@/i18n";
import TagH1 from "@/components/global/TagH1.astro";
import TagP from "@/components/global/TagP.astro";
import { ChevronRight } from "lucide-react";
import { Natgeo, Tripadvaisor, Wordl } from "@/icons/allIcons";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const seoMetaData = {
  title: i18n?.Selection?.ABOUT_US_PAGE?.TITLE || "Cenote Adventure",
  description: i18n?.SEO?.ABOUT_US_PAGE?.DESCRIPTION || "Default description",
};

const related_awards = [
  {
    name: "National Geography",
    image: Natgeo,
  },
  {
    name: "World Travel Awards",
    image: Wordl,
  },
  {
    name: "Trip Advisor",
    image: Tripadvaisor,
  },
];
---
  <section class="bg-[#EDF4FC] py-24 md:py-40 px-6 overflow-hidden -mt-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <div class="lg:max-w-md md:max-w-2xl px-4">
        <div class="w-16 h-[1px] bg-[#006083] mb-12"></div>
        <TagH1
          class="font-serif md:text-4xl text-[#001524] leading-[1.2] tracking-tight -mb-10"
        >
          {i18n.HOME_PAGE.AWARDS.TITLE}
        </TagH1>
      </div>
      <div class="flex flex-col">
        <TagP
          class="text-[#001524]/60 lg:text-lg md:text-2xl leading-[1.7]"
        >
          {i18n.HOME_PAGE.AWARDS.DESCRIPTION1}
        </TagP>

        <div class="flex flex-col gap-5 mx-auto md:max-w-4xl">
          <TagP
            class="text-[#001524]/60 lg:text-lg md:text-2xl leading-[1.7] -mt-30"
          >
            {i18n.HOME_PAGE.AWARDS.DESCRIPTION2}
          </TagP>

          <div>
            <a
              href="/about"
              class="inline-block text-[#005B71] uppercase tracking-[0.2em] text-sm font-bold border-b-2 border-[#005B71]/30 pb-1 hover:border-[#005B71] transition-all duration-300"
            >
              {i18n.HOME_PAGE.AWARDS.DESCRIP_LINK}
            </a>
          </div>
        </div>
      </div>
    </div>
   <!-- Cambiamos grid-cols-1 por grid-cols-3 directamente para que sea compacto siempre -->
<div class="grid grid-cols-3 md:grid-cols-3 gap-4 md:gap-8 mt-12 md:mt-20 mx-auto max-w-5xl px-4">
  {
    related_awards.map((activity) => (
      <div class="flex flex-col items-center text-center p-2 md:p-6">
        {/* Reducimos la altura del contenedor en móvil (h-12) */}
        <div class="h-12 md:h-20 w-full flex items-center justify-center mb-3 md:mb-6">
          <img
            src={activity.image.src}
            alt={activity.name}
            class="h-full w-auto max-w-[80px] md:max-w-[180px] object-contain opacity-80  transition-all"
          />
        </div>

        {/* Texto más pequeño en móvil para que quepa en una línea o dos */}
        <h4 class="text-[#001524] text-[8px] md:text-sm tracking-[0.1em] uppercase font-semibold leading-tight">
          {activity.name}
        </h4>
      </div>
    ))
  }
</div>
</div>
</div>
  </div>
</section>

<script>
  window.addEventListener("scroll", () => {
    const heroImg = document.getElementById("hero-img");
    if (heroImg) {
      const scrollValue = window.scrollY;
      heroImg.style.transform = `translateY(${scrollValue * 0.3}px) scale(1.05)`;
    }
  });
</script>

<style>
  /* Personalización extra para el scroll de la página */
  main {
    scroll-behavior: smooth;
  }
</style>
