---
import { getI18N } from "@/i18n";
import TagH1 from "@/components/global/TagH1.astro";
import TagP from "@/components/global/TagP.astro";
import { ChevronRight } from "lucide-react";
import { Natgeo, Tripadvaisor, Wordl } from "@/icons/allIcons";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const seoMetaData = {
  title: i18n?.Selection?.ABOUT_US_PAGE?.TITLE || "Cenote Adventure",
  description: i18n?.SEO?.ABOUT_US_PAGE?.DESCRIPTION || "Default description",
};

const relatedActivities = [
  {
    name: "National Geography",
    image: Natgeo,
  },
  {
    name: "World Travel Awards",
    image: Wordl,
  },
  {
    name: "Trip Advisor",
    image: Tripadvaisor,
  },
];
---
  <section class="bg-[#F8FAFC] py-24 md:py-40 px-6 overflow-hidden -mt-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <div class="lg:max-w-md md:max-w-2xl px-4">
        <div class="w-16 h-[1px] bg-[#006083] mb-12"></div>
        <TagH1
          class="font-serif text-4xl md:text-5xl lg:text-6xl text-[#001524] leading-[1.2] tracking-tight -mb-10"
        >
          {i18n.HOME_PAGE.AWARDS.TITLE}
        </TagH1>
      </div>

      <div class="flex flex-col">
        <TagP
          class="text-[#001524]/60 text-lg lg:text-lg md:text-2xl leading-[1.7]"
        >
          {i18n.HOME_PAGE.AWARDS.DESCRIPTION1}
        </TagP>

        <div class="flex flex-col gap-5 mx-auto md:max-w-4xl">
          <TagP
            class="text-[#001524]/60 text-lg lg:text-lg md:text-2xl leading-[1.7] -mt-30"
          >
            {i18n.HOME_PAGE.AWARDS.DESCRIPTION2}
          </TagP>

          <div>
            <a
              href="/about"
              class="inline-block text-[#005B71] uppercase tracking-[0.2em] text-sm font-bold border-b-2 border-[#005B71]/30 pb-1 hover:border-[#005B71] transition-all duration-300"
            >
              {i18n.HOME_PAGE.AWARDS.DESCRIP_LINK}
            </a>
          </div>
        </div>
      </div>
    </div>
   <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20 mx-auto max-w-5xl">
  {
    relatedActivities.map((activity) => (
      <a
        href="/activities/"
        class="group cursor-pointer flex flex-col items-center text-center p-6 rounded-xl hover:bg-white hover:shadow-md transition-all duration-300"
      >
        {/* Contenedor con altura controlada */}
        <div class="h-16 md:h-20 w-full flex items-center justify-center mb-6">
          <img
            src={activity.image.src}
            alt={activity.name}
            class="h-full max-w-[150px] md:max-w-[180px] object-contain opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
          />
        </div>

        <h4 class="text-[#001524] text-xs md:text-sm tracking-[0.1em] uppercase line-clamp-2 min-h-[2.5rem] font-semibold">
          {activity.name}
        </h4>

        <div class="text-[10px] uppercase tracking-widest text-gray-400 flex items-center justify-center gap-1 mt-2 group-hover:text-[#005B71] transition-colors">
          {i18n.HOME_PAGE.AWARDS.DESCRIP_LINK} <ChevronRight size={14}/>
        </div>
      </a>
    ))
  }
</div>
  </div>
</section>

<script>
  window.addEventListener("scroll", () => {
    const heroImg = document.getElementById("hero-img");
    if (heroImg) {
      const scrollValue = window.scrollY;
      heroImg.style.transform = `translateY(${scrollValue * 0.3}px) scale(1.05)`;
    }
  });
</script>

<style>
  /* Personalización extra para el scroll de la página */
  main {
    scroll-behavior: smooth;
  }
</style>
