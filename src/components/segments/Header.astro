---
import { getI18N } from "@/i18n";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@/i18n/utils";
import { Menu, X } from "lucide-react";
import LanguageSelector from "./LanguageSelector.astro";
import { Logo_icono_cenote, LogoContainer } from "@/icons/allIcons";

const { currentLocale } = Astro;
const { offI18n } = Astro.props;
const i18n = getI18N({ currentLocale }) as any;
const lang = getLangFromUrl(Astro.url);
const k = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navigation = [
  { title: k("nav.home"), link: translatePath("/") },
  { title: k("nav.cenoteTrail"), link: translatePath("/cenote-trail/") }, // Llave primaria en inglés
  { title: k("nav.blog"), link: translatePath("/404/") },
  { title: k("nav.about"), link: translatePath("/about/") },
  { title: k("nav.contact"), link: translatePath("/contact/") }, // Llave primaria en inglés
];
---

<header
  class="fixed top-0 w-full z-50 transition-all duration-500 flex items-center border-b border-transparent h-24"
  id="main-header"
>
  <div
    class="max-w-[1800px] mx-auto px-4 md:px-20 w-full flex items-center justify-between h-full"
  >
    <div class="flex-none w-14 lg:hidden">
      <button
        class="text-white p-2 transition-colors duration-500"
        id="open-menu"
      >
        <Menu size={30} strokeWidth={1.5} />
      </button>
    </div>

    <div id="logo-container" class="text-white transition-colors duration-500">
      <a
        href={translatePath("/")}
        class="block hover:opacity-90 transition-opacity"
      >
        <div
          id="logo-completo"
          class="transition-all duration-500 opacity-100 block"
        >
          <LogoContainer class="h-12 lg:h-16 p-1" />
        </div>

        <div
          id="logo-reducido"
          class="transition-all duration-500 opacity-0 hidden"
        >
          <Logo_icono_cenote class="h-12 lg:h-16 p-1" />
        </div>
      </a>
    </div>

    <nav class="hidden lg:flex flex-1 justify-center">
      <ul class="flex gap-10">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.link}
                class="nav-link text-[12px] uppercase tracking-[0.3em] text-white hover:opacity-60 transition-all font-medium"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex-none w-14 lg:w-auto flex justify-end">
      <div
        class="flex items-center gap-5 text-white transition-colors duration-500"
        id="icon-group"
      >
        {!offI18n && <LanguageSelector />}
      </div>
    </div>
  </div>

  <div
  id="mobile-drawer"
  class="fixed inset-0 bg-[#006083] z-[60] -translate-x-full transition-transform duration-500 ease-in-out flex flex-col p-10 justify-between"
>
  <div>
    <div class="flex justify-between items-center">
      <LogoContainer class="h-15 text-white" />
      
      <button id="close-menu" class="text-white p-2">
        <X size={35} strokeWidth={1} />
      </button>
    </div>

    <nav class="mt-20 text-center">
      <ul class="flex flex-col gap-10">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.link}
                class="font-serif text-4xl italic text-white block hover:opacity-70 transition-opacity"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="flex flex-col items-center gap-6 mb-15">
    <div class="h-[1px] w-20 bg-white/30"></div>
    <div class="flex gap-8 text-white">
      <a href="#" class="hover:scale-110 transition-transform" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
      </a>
      <a href="#" class="hover:scale-110 transition-transform" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="#" class="hover:scale-110 transition-transform" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
      </a>
    </div>
  </div>
</div>
</header>

<script>
  const header = document.getElementById("main-header");
  const logoCompleto = document.getElementById("logo-completo");
  const logoReducido = document.getElementById("logo-reducido");
  const logoContainer = document.getElementById("logo-container");
  const iconGroup = document.getElementById("icon-group");
  const navLinks = document.querySelectorAll(".nav-link");
  const openBtn = document.getElementById("open-menu");
  const drawer = document.getElementById("mobile-drawer");
  const closeBtn = document.getElementById("close-menu");

  const updateStyles = () => {
    const isScrolled = window.scrollY > 50;
    
    const isSpecialPage = ['/contact', '/404'].some(path => 
      window.location.pathname.includes(path)
    );
    
    const useDarkTheme = isScrolled || isSpecialPage;

    header?.classList.toggle("bg-[#EDF4FC]", useDarkTheme);
    header?.classList.toggle("shadow-sm", useDarkTheme);
    header?.classList.toggle("h-20", useDarkTheme);
    header?.classList.toggle("h-24", !useDarkTheme);
    header?.classList.toggle("border-slate-200", useDarkTheme);

    if (useDarkTheme) {
      logoCompleto?.classList.add("hidden", "opacity-0");
      logoReducido?.classList.remove("hidden");
      setTimeout(() => logoReducido?.classList.remove("opacity-0"), 10);
    } else {
      logoReducido?.classList.add("hidden", "opacity-0");
      logoCompleto?.classList.remove("hidden");
      setTimeout(() => logoCompleto?.classList.remove("opacity-0"), 10);
    }

    const textColor = useDarkTheme ? "text-[#002B49]" : "text-white";
    const oldColor = useDarkTheme ? "text-white" : "text-[#002B49]";

    [logoContainer, iconGroup, openBtn].forEach((el) => {
      el?.classList.add(textColor);
      el?.classList.remove(oldColor);
    });

    navLinks.forEach((link) => {
      link.classList.add(textColor);
      link.classList.remove(oldColor);
    });
  };

  window.addEventListener("scroll", updateStyles);
  document.addEventListener("DOMContentLoaded", updateStyles);
  document.addEventListener("astro:after-swap", updateStyles);
  
  openBtn?.addEventListener("click", () => {
    drawer?.classList.remove("-translate-x-full");
    document.body.style.overflow = "hidden";
    // Añadimos la clase para ocultar el sticky
    document.body.classList.add('menu-is-open');
  });

  closeBtn?.addEventListener("click", () => {
    drawer?.classList.add("-translate-x-full");
    document.body.style.overflow = "";
    // Quitamos la clase para que el sticky vuelva a aparecer
    document.body.classList.remove('menu-is-open');
  });
</script>

<style>
  /* Tipografía Serif para el Menú Móvil */
  @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400&display=swap");

  .font-serif {
    font-family: "Playfair Display", serif;
  }
 
  #sticky-product-card {
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 40; /* Por debajo del menú móvil */
  }

 
  body.menu-is-open #sticky-product-card {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }
  #mobile-drawer {
    z-index: 100;
  }
</style>
