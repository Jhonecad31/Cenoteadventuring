---
import { getI18N } from "@/i18n";
import Layout from "@/layouts/BaseLayout.astro";
import BtnModalBokun from "@/components/others/BtnBokun";
import TagH3 from "@/components/global/TagH3.astro";
import { getLangFromUrl, useTranslatedPath } from "@/i18n/utils";
import {
  Star,
  Clock,
  Users,
  Calendar,
  Truck,
  Check,
  X,
  ChevronRight,
  Info,
  Bug,
  Footprints,
  Shirt,
  Sun,
  Wallet,
  Waves,
  Wind,
  Bus,
} from "lucide-react";
import {
  Beach_taco,
  Extreme_adventuring,
  Snorkeling,
  Cancun_horse,
  CenoteAdventure02,
} from "@/icons/allIcons";

const iconMap: Record<string, any> = {
  Beach_taco: Beach_taco,
  Extreme_adventuring: Extreme_adventuring,
  Snorkeling: Snorkeling,
  Cancun_horse: Cancun_horse,
  CenoteAdventuring: CenoteAdventure02,
};
const tour = {
  rating: 4.8,
  reviews: 1982,
};
const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const relatedActivities = [
  {
    name: "Beach Taco Tour",
    image: "Cenote-Adventuring/tacotaco.webp",
    slug: "beach-taco-tour",
    iconKey: "Beach_taco",
    link: "https://extremeadventurecancun.com/city-taco-tour-puerto-morelos/",
  },
  {
    name: "Extreme Adventuring",
    image: "Cenote-Adventuring/motomoto.webp",
    slug: "extreme-adventuring",
    iconKey: "Extreme_adventuring",
    link: "https://extremeadventurecancun.com/extreme-adventuring-atv-in-cancun/",
  },
  {
    name: "Snorkel Adventuring",
    image: "Cenote-Adventuring/snorkelsnorkel.webp",
    slug: "snorkel-adventuring",
    iconKey: "Snorkeling",
    link: "https://extremeadventurecancun.com/extreme-snorkeling-cancun/",
  },
  {
    name: "Extreme Horseback Riding",
    image: "Cenote-Adventuring/Horse.webp",
    slug: "extreme-adventuring-horse-back-riding",
    iconKey: "Cancun_horse",
    link: "https://extremeadventurecancun.com/extreme-adventuring-horse-back-riding/",
  },
];
const plans = [
  {
    id: "CENOTE",
    image: "Cenote-Adventuring/CenoteA.3.webp",
    logo: "/Cenote-Adventuring/Logo-cenote.svg",
    price: 70,
    oldPrice: 80,
    href: translatePath("/pricing-regular-page"),
  },
  {
    id: "PRIVATE",
    image: "Cenote-Adventuring/Card.1.webp",
    logo: "/Cenote-Adventuring/Logo-cenote.svg",
    price: 70,
    oldPrice: 80,
    href: translatePath("/pricing-private-page"),
    priority: true,
  },
];
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const cloudEndpoint = "https://ik.imagekit.io/pos7v26vx";
const duration = 4;
const minimumAge = 5;
const images = {
  card1: "Cenote-Adventuring/CenoteA.3.webp",
  card2: "Cenote-Adventuring/Card.1.webp",
  logoCenote: "/Cenote-Adventuring/Logo-cenote.svg",
};

const dataForm = {
  bookingChannel: "1e6b5f4a-008a-4afb-879f-7a26209e23e6",
  idCalendar: "898507",
  title: i18n.DETAIL_PAGE.FORM_RESERVATION.BOKUN,
  btnBook: i18n.DETAIL_PAGE.FORM_RESERVATION.BUTTON,
  btnCloseText: "Close",
};

const getUrl = (id: string, w = 800) =>
  `${cloudEndpoint}/tr:w-${w},q-80,f-auto/${id}`;

const Mux_playback_Id = "JBYfgKj5kFEGmOreVx8w6X4LhrMlcOZsCoxU33rmm5c";

const seoMetaData = {
  title: i18n.SEO.REGULAR_CENOTE.INTRO.TITLE,
  description: i18n.SEO.REGULAR_CENOTE.INTRO.DESCRIPTION,
};
---

<Layout seo={seoMetaData}>
  <main class="bg-[#F8FAFC] pb-20 overflow-x-hidden">
    <section
      class="relative h-[80vh] flex items-center justify-center overflow-hidden"
    >
      <mux-player
        playback-id={Mux_playback_Id}
        autoplay
        muted
        loop
        playsinline
        no-controls
        preload="auto"
        class="hero-video brightness-[0.2]"></mux-player>
      <div class="relative z-10 text-center text-white px-6">
        <h1
          class="font-serif italic text-4xl md:text-4xl mb-6 tracking-tight drop-shadow-lg"
        >
          {i18n.DETAIL_PAGE.REGULAR_CENOTE.HERO.TITLE}
        </h1>
        <p class="uppercase tracking-[0.5em] text-sm font-light opacity-90">
          {i18n.DETAIL_PAGE.REGULAR_CENOTE.HERO.DESCRIPTION}
        </p>
        <div
          class="flex items-center justify-center tracking-[0.5em] text-xs lg:text-sm relative h-[5vh] mt-3"
        >
          <Star className="text-yellow-400 fill-yellow-300" size={15} />
          <span class="font-bold text-[#ffffff]"> {tour.rating}</span>
          <span class="text-white">({tour.reviews} reviews)</span>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12 md:py-24 space-y-16">
      <div
        class="grid grid-cols-1 lg:grid-cols-12 lg:gap-24 items-center justify-center"
      >
        <div class="relative lg:col-span-7 h-[450px] md:h-[600px] w-full">
          <div
            class="absolute top-0 left-4 w-[60%] h-[80%] overflow-hidden shadow-lg z-10"
          >
            <img
              src={getUrl(images.card1, 800)}
              class="w-full h-full object-cover"
              alt="Cenote"
              loading="lazy"
            />
          </div>
          <div
            class="absolute bottom-4 right-4 w-[60%] h-[80%] overflow-hidden shadow-2xl z-20"
          >
            <img
              src={getUrl(images.card2, 800)}
              class="w-full h-full object-cover"
              alt="Private"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5 flex flex-col">
          <hr class="border-black/50 w-full mb-6" />
          <h2
            class="font-serif text-3xl md:text-5xl text-[#001524] mb-6 leading-tight"
          >
            {i18n.DETAIL_PAGE.REGULAR_CENOTE.INTRO.TITLE}
          </h2>
          <p
            class="text-gray-600 leading-relaxed text-base md:text-lg font-light max-w-prose"
          >
            {i18n.DETAIL_PAGE.REGULAR_CENOTE.INTRO.DESCRIPTION}
          </p>
          <hr class="border-black/50 w-full mt-6" />
        </div>
      </div>
    </section>
    <section class="mx-auto max-w-screen-2xl px-6 mt-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-start">
        
        <div class="lg:col-span-8 space-y-6">
          {/* GRID DE INFORMACIÓN RÁPIDA */}
          <div
            class="bg-[#EDF4FC] rounded-md p-6 shadow-sm grid grid-cols-2 md:grid-cols-4 gap-9 mb-16"
          >
            {/* DURACIÓN */}
            <div
              class="flex flex-col items-center text-center gap-3 md:border-r border-gray-100 last:border-none px-2"
            >
              <Clock size={30} className="text-gray-400" />
              <div class="flex flex-col">
                <span
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-400"
                >
                  {i18n.DETAIL_PAGE.GENERAL.DURATION}
                </span>
                <span class="text-xs md:text-sm font-semibold text-gray-800">
                  {duration}
                  {i18n.DETAIL_PAGE.GENERAL.HOURS} ({
                    i18n.DETAIL_PAGE.GENERAL.APPROX
                  })
                </span>
              </div>
            </div>

            {/* EDAD */}
            <div
              class="flex flex-col items-center text-center gap-3 md:border-r border-gray-100 last:border-none px-2"
            >
              <Users size={30} className="text-gray-400" />
              <div class="flex flex-col">
                <span
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-400"
                >
                  {i18n.DETAIL_PAGE.GENERAL.AGE_REQUIREMENT}
                </span>
                <span class="text-xs md:text-sm font-semibold text-gray-800">
                  {minimumAge}
                  {i18n.DETAIL_PAGE.GENERAL.YEARS_AND_OLDER}
                </span>
              </div>
            </div>

            {/* HORARIO */}
            <div
              class="flex flex-col items-center text-center gap-3 md:border-r border-gray-100 px-2"
            >
              <Calendar size={30} className="text-gray-400" />
              <div class="flex flex-col">
                <span
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-400"
                >
                  {i18n.DETAIL_PAGE.GENERAL.SCHEDULE}
                </span>
                <span class="text-xs md:text-sm font-semibold text-gray-800"
                  >09:00 | 13:00</span
                >
              </div>
            </div>

            {/* TRANSPORTE */}
            <div class="flex flex-col items-center text-center gap-3 px-2">
              <Truck size={30} className="text-gray-400" />
              <div class="flex flex-col">
                <span
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-gray-400"
                  >Transport</span
                >
                <span class="text-xs md:text-sm font-semibold text-gray-800"
                  >Included</span
                >
              </div>
            </div>
          </div>

          {/* TÍTULO Y DESCRIPCIÓN */}
          <h2
            class="font-serif text-3xl md:text-5xl text-[#001524] leading-tight"
          >
            {i18n.DETAIL_PAGE.REGULAR_CENOTE.OVERVIEW.TITLE}
          </h2>
          <div
            class="text-gray-600 leading-relaxed text-base md:text-lg font-light space-y-5"
          >
            <p>{i18n.DETAIL_PAGE.REGULAR_CENOTE.OVERVIEW.DESCRIPTION1}</p>
            <p>{i18n.DETAIL_PAGE.REGULAR_CENOTE.OVERVIEW.DESCRIPTION2}</p>
          </div>

          <hr class="border-black/50 w-full" />

          {/* SECCIÓN DE ACORDEONES EXCLUSIVOS (Solo uno abierto a la vez) */}
          <div class="divide-y divide-gray-200">
            {/* 1. INCLUSIONES (Abierto por defecto) */}
            <details class="group py-6" name="tour-info" open>
              <summary
                class="flex justify-between items-center cursor-pointer list-none"
              >
                <span class="text-2xl md:text-3xl font-serif text-[#001524]">
                  {i18n.DETAIL_PAGE.REGULAR_CENOTE.INCLUSIONS.TITLE}
                </span>
                <div
                  class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center group-open:rotate-180 transition-transform duration-300"
                >
                  <ChevronRight className="rotate-90 text-gray-500" size={20} />
                </div>
              </summary>
              <div class="mt-8">
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
                  {
                    i18n.DETAIL_PAGE.REGULAR_CENOTE.INCLUSIONS.INCLUDES.map(
                      (text) => (
                        <li class="flex items-start gap-3 text-base md:text-lg font-light text-gray-600">
                          <Check
                            className="text-[#006083] mt-1 shrink-0"
                            size={20}
                          />
                          <span
                            class={
                              text.includes("Conservation Fee")
                                ? "font-bold text-gray-900"
                                : ""
                            }
                          >
                            {text}
                          </span>
                        </li>
                      ),
                    )
                  }
                  {
                    i18n.DETAIL_PAGE.REGULAR_CENOTE.INCLUSIONS.NOT_INCLUDES.map(
                      (text) => (
                        <li class="flex items-start gap-3 text-base md:text-lg font-light text-gray-600">
                          <X className="text-red-500 mt-1 shrink-0" size={20} />
                          <span>{text}</span>
                        </li>
                      ),
                    )
                  }
                </ul>
              </div>
            </details>

            {/* 2. POR QUÉ ELEGIRNOS */}
            <details class="group py-6" name="tour-info">
              <summary
                class="flex justify-between items-center cursor-pointer list-none"
              >
                <span class="text-2xl md:text-3xl font-serif text-[#001524]">
                  {
                    i18n.DETAIL_PAGE.REGULAR_CENOTE
                      .WHY_CHOOSE_OUR_CENOTES_CANCUN_TOUR.TITLE
                  }
                </span>
                <div
                  class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center group-open:rotate-180 transition-transform duration-300"
                >
                  <ChevronRight className="rotate-90 text-gray-500" size={20} />
                </div>
              </summary>
              <div class="mt-4 text-gray-600 leading-relaxed font-light">
                <p>
                  {
                    i18n.DETAIL_PAGE.REGULAR_CENOTE
                      .WHY_CHOOSE_OUR_CENOTES_CANCUN_TOUR.DESCRIPTION
                  }
                </p>
                <div class="bg-[#EDF4FC] rounded-lg mt-5 p-10">
                  <TagH3
                    >{
                      i18n.DETAIL_PAGE.REGULAR_CENOTE
                        .WHY_CHOOSE_OUR_CENOTES_CANCUN_TOUR
                        .THE_UNIQUE_FEATURES_OF_OUR_CENOTE_TOUR.TITLE
                    }</TagH3
                  >
                  <p class="mt-2">
                    {
                      i18n.DETAIL_PAGE.REGULAR_CENOTE
                        .WHY_CHOOSE_OUR_CENOTES_CANCUN_TOUR
                        .THE_UNIQUE_FEATURES_OF_OUR_CENOTE_TOUR.DESCRIPTION
                    }
                  </p>
                  <ul
                    class="list-decimal list-inside mt-10 space-y-4 text-base/loose"
                  >
                    {
                      i18n.DETAIL_PAGE.REGULAR_CENOTE.WHY_CHOOSE_OUR_CENOTES_CANCUN_TOUR.THE_UNIQUE_FEATURES_OF_OUR_CENOTE_TOUR.THE_UNIQUE_FEATURES_LIST.map(
                        (item) => (
                          <li>
                            <strong>{item.TITLE}:</strong> {item.DESCRIPTION}
                          </li>
                        ),
                      )
                    }
                  </ul>
                </div>
              </div>
            </details>

            {/* 3. QUÉ DEBERÍAS SABER */}
            <details class="group py-6" name="tour-info">
              <summary
                class="flex justify-between items-center cursor-pointer list-none"
              >
                <span class="text-2xl md:text-3xl font-serif text-[#001524]">
                  {i18n.DETAIL_PAGE.REGULAR_CENOTE.WHAT_YOU_SHOULD_KNOW.TITLE}
                </span>
                <div
                  class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center group-open:rotate-180 transition-transform duration-300"
                >
                  <ChevronRight className="rotate-90 text-gray-500" size={20} />
                </div>
              </summary>
              <div class="mt-8">
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {
                    i18n.DETAIL_PAGE.REGULAR_CENOTE.WHAT_YOU_SHOULD_KNOW.LIST.map(
                      (item) => (
                        <li class="flex items-start gap-3">
                          <Info
                            className="text-gray-400 mt-1 shrink-0"
                            size={18}
                          />
                          <span class="text-gray-600 font-light text-sm md:text-base">
                            {item}
                          </span>
                        </li>
                      ),
                    )
                  }
                </ul>
              </div>
            </details>
          </div>

          {/* QUÉ TRAER (Sección estática fuera de los acordeones) */}
          <div class="py-12">
            <h2 class="text-2xl md:text-3xl font-serif mb-8 text-[#001524]">
              {i18n.DETAIL_PAGE.REGULAR_CENOTE.WHAT_TO_BRING.TITLE}
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
              {
                Object.entries(i18n.DETAIL_PAGE.REGULAR_CENOTE.WHAT_TO_BRING)
                  .filter(([key]) => key !== "TITLE")
                  .map(([key, value]) => {
                    let Icon = Shirt;
                    if (key === "SUNSCREEN") Icon = Sun;
                    if (key === "TOWEL" || key === "CLOTHES") Icon = Wind;
                    if (key === "SWIMSUIT") Icon = Waves;
                    if (key === "SHOES") Icon = Footprints;
                    if (key === "CASH") Icon = Wallet;
                    if (key === "REPELLENT") Icon = Bug;

                    return (
                      <div class="flex items-start gap-5 group transition-all">
                        <div class="flex-shrink-0 w-12 h-12 bg-[#EDF4FC] rounded-lg flex items-center justify-center group-hover:bg-[#006083] transition-colors duration-300">
                          <Icon
                            className="text-[#006083] group-hover:text-white transition-colors duration-300"
                            size={24}
                          />
                        </div>
                        <div>
                          <h3 class="font-serif text-lg text-[#001524] font-semibold mb-1">
                            {value.TITLE}
                          </h3>
                          <p class="text-sm text-gray-500 leading-relaxed max-w-md">
                            {value.DESCRIPTION}
                          </p>
                        </div>
                      </div>
                    );
                  })
              }
            </div>
          </div>

          {/* SECCIÓN FAQS */}
          <div class="mt-20">
            <h2 class="text-2xl md:text-3xl font-serif mb-8 text-[#001524]">
              FAQs
            </h2>
            <div class="flex flex-col gap-4">
              {
                i18n.DETAIL_PAGE.REGULAR_CENOTE.FAQS.FAQS.map((faq, index) => (
                  <details
                    key={index}
                    name="faq-group"
                    class="group bg-[#EDF4FC] rounded-lg border border-white/50 shadow-sm overflow-hidden transition-all duration-300"
                  >
                    <summary class="flex justify-between items-center cursor-pointer list-none p-8 text-left font-medium text-[#001524] hover:text-[#005B71] transition-colors">
                      <span class="pr-4">{faq.question}</span>
                      <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center">
                        <span class="text-3xl font-light text-gray-400 transition-transform duration-300 group-open:rotate-45 block leading-none">
                          +
                        </span>
                      </div>
                    </summary>
                    <div class="px-8 pb-8 animate-fade-in border-t border-blue-100 pt-4">
                      <p class="text-gray-600 leading-relaxed font-light">
                        {faq.answer}
                      </p>
                    </div>
                  </details>
                ))
              }
            </div>
          </div>
        </div>
        <aside class="hidden lg:block lg:col-span-4 lg:mt-0">
          <div class="w-full border-2 border-gray-200 p-2 rounded-[22px]">
            <div
              class="w-full bg-gray-50/50 p-6 rounded-xl text-center border border-gray-100"
            >
              <div class="mb-4">
                <p class="text-xs lg:text-sm text-gray-400 line-through">
                  {i18n.DETAIL_PAGE.FORM_RESERVATION.PRICE_FROM} $80 USD
                </p>
                <div class="text-3xl lg:text-4xl font-bold text-[#001524]">
                  $70 USD
                </div>
                <p class="text-xs lg:text-sm text-gray-500">
                  {i18n.DETAIL_PAGE.FORM_RESERVATION.PER_PERSON}
                </p>
              </div>

              <div class="grid grid-cols-2 gap-3 mb-6">
                <div class="bg-white p-3 rounded-lg border border-gray-100">
                  <span
                    class="inline-block text-[10px] lg:text-xs font-bold text-white bg-[#006083] rounded-full px-2 mb-1"
                    >10%</span
                  >
                  <p class="text-[10px] lg:text-xs leading-tight text-gray-600">
                    {
                      i18n.DETAIL_PAGE.FORM_RESERVATION.EARLY_BIRD
                        .BOOKING_15_DAYS
                    }
                  </p>
                  <p class="text-sm lg:text-base font-bold">$66 USD</p>
                </div>
                <div class="bg-white p-3 rounded-lg border border-gray-100">
                  <span
                    class="inline-block text-[10px] lg:text-xs font-bold text-white bg-[#006083] rounded-full px-2 mb-1"
                    >20%</span
                  >
                  <p class="text-[10px] lg:text-xs leading-tight text-gray-600">
                    {
                      i18n.DETAIL_PAGE.FORM_RESERVATION.EARLY_BIRD
                        .BOOKING_30_DAYS
                    }
                  </p>
                  <p class="text-sm lg:text-base font-bold">$70 USD</p>
                </div>
              </div>

              <BtnModalBokun client:visible data={dataForm} isSticky={false} />
            </div>
          </div>
        </aside>
      </div>
    </section>

    <div
  id="sticky-product-card"
  class="fixed bottom-6 left-4 right-4 lg:hidden z-40"
>
      <div
        class="bg-[#EDF4FC] rounded-[24px] p-5 shadow-[0_20px_60px_rgba(0,0,0,0.5)] border border-white/5"
      >
        <div class="flex items-start gap-4 mb-1">
          <div class="flex-shrink-0 w-20">
            <img
              src={getUrl(images.logoCenote)}
              alt="Logo"
              class="w-full h-auto object-contain"
            />
          </div>
          <div class="flex flex-col flex-grow pt-1">
            <p class="text-black font-normal text-xs mb-1">
              {i18n.HOME_PAGE.CHOOSE_PLAN.PLANS.PRIVATE.TITLE}
            </p>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-black font-bold text-2xl tracking-tight">
                $70 USD
              </span>
              <span class="text-black/65 text-[10px] font-light">
                {i18n.DETAIL_PAGE.FORM_RESERVATION.PER_PERSON}
              </span>
            </div>
          </div>
        </div>
       <div slot="sticky-button">
    <BtnModalBokun client:load data={dataForm} variant="sticky" />
  </div>
      </div>
    </div>
  </main>
  <section class="bg-[#F8FAFC] py-20 px-6 overflow-hidden -mt-20">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="font-serif text-3xl text-[#001524] mb-4"></h2>
      <p class="text-gray-500 max-w-2xl mx-auto"></p>
    </div>

    <div class="swiper mySwiper pb-12">
      <div class="swiper-wrapper">
        {
          relatedActivities.map((activity) => {
            const IconComponent = iconMap[(activity as any).iconKey];
            return (
              <div class="swiper-slide">
                <a href={activity.link} class="group block">
                  <div class="relative aspect-[3/4] overflow-hidden mb-6 shadow-sm bg-gray-100">
                    <img
                      src={getUrl(activity.image, 600)}
                      alt={activity.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    />
                    {IconComponent && (
                      <div class="absolute top-4 right-4 p-2.5 rounded-lg flex items-center justify-center z-10">
                        <div class="w-20 h-20 lg:w-15 lg:h-15 flex items-center justify-center">
                          <IconComponent className="w-full h-full object-contain" />
                        </div>
                      </div>
                    )}
                  </div>
                  <div class="text-left">
                    <h3 class="font-serif text-xl text-[#001524] mb-2">
                      {activity.name}
                    </h3>
                    <a href={activity.link} target="_blank">
                      <div class="text-[11px] font-bold tracking-widest text-[#001524] lg:text-gray-400 flex items-center gap-2 group-hover:text-[#006083] transition-colors">
                        {i18n.DETAIL_PAGE.GENERAL.BTNGENERAL}
                        {""}
                        <ChevronRight
                          size={14}
                          className="group-hover:translate-x-1 transition-transform"
                        />
                      </div>
                    </a>
                  </div>
                </a>
              </div>
            );
          })
        }
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>
</Layout>


<style>
  @import "swiper/css";
  @import "swiper/css/pagination";

  .swiper-pagination-bullet-active {
    background: #005b71 !important;
  }

  .swiper-slide {
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .swiper-slide-active {
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .swiper-slide {
      opacity: 1 !important;
    }
  }

  .bokun-calendar-container {
    overflow: visible !important;
    z-index: 40 !important; 
  }

  mux-player {
    position: absolute;
    inset: 0;
    width: 100%; 
    height: 100%;
    z-index: 0;
    --controls: none;
    --media-object-fit: cover;
  }

  mux-player::part(video) {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.4s ease-out forwards;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, Pagination } from "swiper/modules";
  import "@mux/mux-player";

  function initSwiper() {
    new Swiper(".mySwiper", {
      modules: [Pagination, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: { delay: 4000, disableOnInteraction: false },
      pagination: { el: ".swiper-pagination", clickable: true },
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 4, allowTouchMove: false, loop: false },
      },
    });
  }

  initSwiper();
  document.addEventListener("astro:page-load", initSwiper);
</script>
