---
import styleImg from "@/styles/style-img.css"
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";
const getUrl = (id: string, w = 1200) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;

// 2. Mapeo de tus imágenes a la nueva estructura asimétrica
const gallerySections = [
  // Sección 1: Imagen sola, tamaño medio (como la de 'In Rock')
  {
    type: "single",
    image: getUrl("CenoteA.2_njvbos"),
    sizeClass: "w-[400px] h-[300px]",
  },
  // Sección 2: Imagen sola, muy grande (como la del guitarrista/jeans)
  {
    type: "single",
    image: getUrl("CenoteA.1_ntnmsp"),
    sizeClass: "w-[300px] h-[450px]", // Superposición negativa
  },
  // Sección 3: Bloque con Texto (como el de '15 SHOWCASE (JANUARY)')
  {
    type: "single",
    image: getUrl("CenoteA.5_tdhqvl"),
    sizeClass: "w-[400px] h-[600x]",
  },
  // Sección 4: Imagen sola, muy alta (como la de la chica en el agua)
  {
    type: "single",
    image: getUrl("CenoteA.3_pzncr9"),
    sizeClass: "w-[300px] h-[300px]",
  },
  // Sección 5: Bloque de imágenes apiladas (para lograr más asimetría)
  {
    type: "stacked",
    image: getUrl("CenoteA.8_jx4f49"),
    sizeClass: "w-[300px] h-[450px]",
  },
  // Sección 6: Imagen final (como el bloque azul)
  {
    type: "single",
    image: getUrl("CenoteA.8_jx4f49"),
    sizeClass: "w-[300px] h-[300px]",
  },
];
---

<section class="asymmetric-gallery-wrapper">
  <div id="grid-gallery-scroll" class="gallery-container hide-scrollbar">
    {
      gallerySections.map((section) => (
        <>
          {/* SECCIÓN INDIVIDUAL (SIMPLE O GRANDE) */}
          {section.type === "single" && (
            <div class={`gallery-item ${section.sizeClass} self-center`}>
              <img
                src={section.image}
                class="img-content"
                alt="Cenote aspect"
                loading="lazy"
              />
            </div>
          )}

          {/* SECCIÓN DE TEXTO (NÚMERO, IMAGEN, LABEL) */}
          {section.type === "text_block" && (
            <div
              class={`gallery-item ${section.sizeClass} flex flex-col self-center`}
            >
              <div class="text-block-layout">
                <div class="block-image-container">
                  <img
                    src={section.image}
                    class="img-content"
                    alt="Content focus"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          )}

          {/* SECCIÓN APILADA (DOS IMÁGENES) */}
          {section.type === "stacked" && (
            <div
              class={`gallery-item ${section.sizeClass} flex flex-col gap-6 self-center`}
            >
              <img
                src={section.image}
                class="h-[45%] img-content"
                alt="Cenote detail top"
                loading="lazy"
              />
            </div>
          )}
        </>
      ))
    }
    <div class="w-[10vw] flex-shrink-0"></div>
  </div>
</section>

<style>
  .asymmetric-gallery-wrapper {
    width: 100%;
    background-color: #f7f7f7; 
    padding: 100px 0;
    cursor: grab;
    user-select: none;
    overflow: hidden;
  }

  .asymmetric-gallery-wrapper:active {
    cursor: grabbing;
  }

  .gallery-container {
    display: flex;
    gap: 10px;
    padding: 0 10vw;
    align-items: center;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    height: 90vh; 
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .gallery-item {
    flex-shrink: 0;
    position: relative;
    z-index: 1; 
  }

  .img-content {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    transition:
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.3s ease;
  }

  .img-content:hover {
    transform: scale(1.02) translateY(-5px); 
    z-index: 10;
    filter: brightness(1.02);
  }
  .text-block-layout {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto 1fr auto;
    gap: 8px;
    align-items: end;
  }

  .block-number {
    grid-column: 1;
    grid-row: 1;
    font-family: monospace; 
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    color: #333;
    align-self: start; 
  }

  .block-image-container {
    grid-column: 1 / -1; 
    grid-row: 2;
    aspect-ratio: 1; 
  }

  .block-label {
    grid-column: 1 / -1;
    grid-row: 3;
    font-family: monospace;
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .gallery-container {
      height: 70vh;
      padding: 0 5vw;
    }
    .gallery-item {
       flex-shrink: 0;
    position: relative;
    z-index: 1; 
  }

    .text-block-layout {
      width: 100%;
    }
  }
</style>

<script>
  const setupGallery = () => {
    const slider = document.getElementById("grid-gallery-scroll");
    if (!slider) return;

    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    slider.addEventListener("mousedown", (e) => {
      isDown = true;
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
      slider.style.scrollBehavior = "auto"; 
    });

    slider.addEventListener("mouseleave", () => (isDown = false));
    slider.addEventListener("mouseup", () => {
      isDown = false;
      slider.style.scrollBehavior = "smooth";
    });

    slider.addEventListener("mousemove", (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2; 
      slider.scrollLeft = scrollLeft - walk;
    });
  };

  setupGallery();
  document.addEventListener("astro:after-swap", setupGallery);
</script>
