---
import { getI18N } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagH2 from "@/components/global/TagH2.astro";
import TagH3 from "@/components/global/TagH3.astro";
import TagP from "@/components/global/TagP.astro";
import BContainer from "@/components/global/BContainer.astro";
import { Laurel1, Laurel2, Laurel3 } from "@/icons/allIcons";
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
const cloudEndpoint = "https://ik.imagekit.io/pos7v26vx";
const images = {
  imgCenote: "/Cenote-Adventuring/CenoteA.6.webp", 
};
const related_awards = [
  {
    name: "National Geography",
    image: Laurel1,
  },
  {
    name: "World Travel Awards",
    image: Laurel2,
  },
  {
    name: "Trip Advisor",
    image: Laurel3,
  },
];

const getUrl = (id: string, w = 800) =>
  `${cloudEndpoint}/tr:w-${w},q-80,f-auto/${id}`;

---

<BaseLayout>
  <main class="bg-[#F8FAFC] overflow-x-hidden">
    
    <section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
      <img
        src={getUrl(images.imgCenote)}
        class="absolute z-0 w-full h-full object-cover scale-[1.05] brightness-[0.4]"
        id="hero-img"
        alt="Cenote Background"
        loading="eager"
      />

      <div class="relative z-10 text-center text-white px-6">
        <h1 class="font-serif italic text-4xl md:text-4xl mb-6 tracking-tight drop-shadow-lg">
          {i18n.ABOUT_US_PAGE.HERO.H1}
        </h1>
        <p class="tracking-[0.6em] font-light text-xs md:text-sm animate-fade-in opacity-90 mx-auto max-w-4xl">
          {i18n.ABOUT_US_PAGE.HERO.DESCRIPTION}
        </p>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto py-24 px-6">
      <BContainer>
        <div class="grid lg:grid-cols-12 gap-16 items-start">
          
          <div class="lg:col-span-5 space-y-6">
            <TagH2 class="font-serif italic text-5xl text-[#006083] leading-tight">
              {i18n.ABOUT_US_PAGE.MISSION.TITLE}
            </TagH2>
            <div class="w-16 h-[1px] bg-[#006083] opacity-30"></div>
            <TagP class="text-lg leading-relaxed text-slate-600 italic">
              "{i18n.ABOUT_US_PAGE.MISSION.STATEMENT}"
            </TagP>
          </div>

          <div class="lg:col-span-7 space-y-8">
            <div class="space-y-6 text-slate-700 leading-relaxed">
               <TagP>{i18n.ABOUT_US_PAGE.HERO.DESCRIPTION}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.HERO.ORIGIN_STORY}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.MISSION.PHILOSOPHY}</TagP>
            </div>

            <div class="pt-10 border-t border-slate-200">
               <TagH3 class="font-serif text-2xl text-[#006083] mb-6 uppercase tracking-widest">
                 {i18n.ABOUT_US_PAGE.FEATURES.H2}
               </TagH3>
               <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                 {i18n.ABOUT_US_PAGE.FEATURES.ITEMS.map((item: string) => (
                   <li class="flex items-center gap-3 text-xs uppercase tracking-widest text-slate-500 font-medium">
                     <span class="size-1.5 bg-[#006083] rounded-full"></span>
                     {item}
                   </li>
                 ))}
               </ul>
            </div>
          </div>

        </div>
      </BContainer>
    </section>

    <section class="bg-white py-24 border-y border-slate-100">
      <div class="max-w-[800px] mx-auto px-6 text-center space-y-8">
        <TagH2 class="font-serif italic text-4xl text-[#006083]">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.H2}
        </TagH2>
        <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.CONTENT}
        </TagP>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left pt-10">
           {i18n.ABOUT_US_PAGE.HIGHLIGHTS.KEY_POINTS.map((point: string) => (
             <div class="border-l border-[#006083]/20 pl-4 py-2">
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#006083] mb-1">Highlight</p>
                <p class="text-sm text-slate-500">{point}</p>
             </div>
           ))}
        </div>
      </div>
    </section>

    <!-- CONTENEDOR PARA ESCRITORIO (Se oculta en móvil) -->
<div class="hidden md:grid grid-cols-3 gap-4 mx-auto max-w-4xl px-4 py-12">
  {
    related_awards.map((activity) => (
      <div class="flex flex-col items-center justify-center">
        <div class="h-40 w-full flex items-center justify-center">
          <img
            src={activity.image.src}
            alt={activity.name}
            class="h-full w-auto max-w-[280px] object-contain opacity-90 transition-all hover:scale-105"
          />
        </div>
      </div>
    ))
  }
</div>

<!-- CONTENEDOR PARA MÓVIL (Carrusel de 1 en 1, se oculta en escritorio) -->
<div class="md:hidden px-4 py-8">
  <div id="awards-carousel-mobile" class="relative w-full" data-carousel="slide">
    <!-- Wrapper -->
    <div class="relative h-48 overflow-hidden rounded-lg">
      {
        related_awards.map((activity, index) => (
          <div class="hidden duration-700 ease-in-out flex items-center justify-center" data-carousel-item>
            <div class="h-32 w-full flex items-center justify-center">
              <img 
                src={activity.image.src} 
                class="max-h-full max-w-[150px] object-contain" 
                alt={activity.name} 
              />
            </div>
          </div>
        ))
      }
    </div>
    
    <!-- Puntos (Indicadores) -->
    <div class="absolute z-30 flex -translate-x-1/2 bottom-0 left-1/2 space-x-3">
      {
        related_awards.map((_, index) => (
          <button 
            type="button" 
            class="w-2 h-2 rounded-full bg-gray-300" 
            aria-current={index === 0 ? "true" : "false"} 
            data-carousel-slide-to={index}>
          </button>
        ))
      }
    </div>
  </div>
</div>

  </main>

 <script>
  import { Carousel } from 'flowbite';

  function initPageLogic() {
    // 1. Lógica del Hero (Parallax)
    const heroImg = document.getElementById("hero-img");
    
    // Solo añadimos el listener si no existe uno previo para evitar duplicados
    window.addEventListener("scroll", () => {
      if (heroImg) {
        const scrollValue = window.scrollY;
        // Limitemos el efecto al área visible del hero para mejorar performance
        if (scrollValue < window.innerHeight) {
          heroImg.style.transform = `translateY(${scrollValue * 0.2}px) scale(1.05)`;
        }
      }
    });

    // 2. Lógica del Carrusel de Laureles (Solo en móvil)
    const $carouselEl = document.getElementById('awards-carousel-mobile');
    if ($carouselEl && window.innerWidth < 768) {
      const items = Array.from($carouselEl.querySelectorAll('[data-carousel-item]')).map((el, index) => ({
        position: index,
        el: el as HTMLElement
      }));

      const indicators = Array.from($carouselEl.querySelectorAll('[data-carousel-slide-to]')).map((el, index) => ({
        position: index,
        el: el as HTMLElement
      }));

      new Carousel($carouselEl, items, {
        defaultPosition: 0,
        interval: 3000,
        indicators: {
          activeClasses: 'bg-blue-600', // Color del punto activo
          inactiveClasses: 'bg-gray-300',
          items: indicators
        }
      });
    }
  }

  // Inicializar en carga inicial y en cambios de página de Astro
  document.addEventListener('DOMContentLoaded', initPageLogic);
  document.addEventListener('astro:page-load', initPageLogic);
</script>

  <style>
    main {
      scroll-behavior: smooth;
    }
    /* Estilo para que el texto sea muy legible y elegante */
    :global(p) {
      letter-spacing: 0.015em;
    }
  </style>
</BaseLayout>