---
import { getI18N } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagH1 from "@/components/global/TagH1.astro";
import TagH2 from "@/components/global/TagH2.astro";
import TagH3 from "@/components/global/TagH3.astro";
import TagP from "@/components/global/TagP.astro";
import BContainer from "@/components/global/BContainer.astro";
import { Laurel1, Laurel2, Laurel3 } from "@/icons/allIcons";
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
const cloudEndpoint = "https://ik.imagekit.io/pos7v26vx";
const images = {
  imgCenote: "/Cenote-Adventuring/CenoteA.6.webp", 
};
const related_awards = [
  {
    name: "National Geography",
    image: Laurel1,
  },
  {
    name: "World Travel Awards",
    image: Laurel2,
  },
  {
    name: "Trip Advisor",
    image: Laurel3,
  },
];

const getUrl = (id: string, w = 800) =>
  `${cloudEndpoint}/tr:w-${w},q-80,f-auto/${id}`;

---

<BaseLayout>
  <main class="bg-[#F8FAFC] overflow-x-hidden">
    
    <section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
      <img
        src={getUrl(images.imgCenote)}
        class="absolute z-0 w-full h-full object-cover scale-[1.05] brightness-[0.4]"
        id="hero-img"
        alt="Cenote Background"
        loading="eager"
      />
      <div class="relative z-10 text-center text-white px-6">
        <h1
          class="font-serif italic text-4xl md:text-4xl mb-6 tracking-tight drop-shadow-lg"
        >
          {i18n.ABOUT_US_PAGE.HERO.H1}
        </h1>
        <p class="tracking-[0.5em] text-sm font-light opacity-90">
          {i18n.ABOUT_US_PAGE.HERO.SUBTITLE}
        </p>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto py-24 px-6">
      <BContainer>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <div class="lg:max-w-md md:max-w-2xl px-4">
        <div class="w-16 h-[1px] bg-[#006083] mb-12"></div>
        <TagH1
          class="font-serif md:text-4xl text-[#001524] leading-[1.2] tracking-tight -mb-10"
        >
          {i18n.ABOUT_US_PAGE.MISSION.TITLE}
        </TagH1>
      </div>
      <div class="flex flex-col">
        <TagP
          class="text-[#001524]/60 lg:text-lg md:text-2xl leading-[1.7]"
        >
           "{i18n.ABOUT_US_PAGE.MISSION.STATEMENT}"
        </TagP>
        <div class="text-[#001524]/60 lg:text-lg md:text-2xl leading-[1.7]">
               <TagP>{i18n.ABOUT_US_PAGE.HERO.DESCRIPTION}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.HERO.ORIGIN_STORY}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.MISSION.PHILOSOPHY}</TagP>
            </div>
      </div>
    </div>
      </BContainer>
    </section>
    <section class="bg-white py-24 border-y border-slate-100">
      <div class="max-w-[800px] mx-auto px-6 text-center space-y-8">
        <TagH1 class="pt-20 max-w-3xl mx-auto px-5 font-serif text-center! md:text-4xl">
    {i18n.ABOUT_US_PAGE.DESTINATION_INFO.H2}
  </TagH1>
        <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.CONTENT}
        </TagP>
        <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.DIFFERENTIATION}
        </TagP>
        <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.EXPERIENCE}
        </TagP>

        <TagH1 class="pt-20 max-w-3xl mx-auto px-5 font-serif text-center! md:text-4xl">
    {i18n.ABOUT_US_PAGE.HIGHLIGHTS.H3}
  </TagH1>
  <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.HIGHLIGHTS.LOCATION}
        </TagP>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left pt-10">
          
           {i18n.ABOUT_US_PAGE.HIGHLIGHTS.KEY_POINTS.map((point: string) => (
             <div class="border-l border-[#006083]/20 pl-4 py-2">
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#006083] mb-1">Highlight</p>
                <p class="text-sm text-slate-500">{point}</p>
             </div>
           ))}
        </div>
      </div>
    </section>

    <!-- seccion para awards -->
    <div id="awards-carousel" class="relative w-full md:block">
  <!-- Wrapper del Carrusel -->
  <div
    class="relative h-48 overflow-hidden rounded-lg md:h-auto md:overflow-visible flex md:grid md:grid-cols-3 gap-4 px-4 items-center"
    id="carousel-wrapper"
  >
    {
      related_awards.map((activity, index) => (
        <div 
          class="duration-700 ease-in-out flex-none w-full md:w-auto md:relative md:block flex items-center justify-center transition-opacity"
          data-carousel-item={index === 0 ? "active" : ""}
        >
          <div class="h-32 md:h-40 w-full flex items-center justify-center">
            <img
              src={activity.image.src}
              alt={activity.name}
              class="h-full w-auto max-w-[150px] md:max-w-[280px] object-contain opacity-90 transition-all hover:scale-105"
            />
          </div>
        </div>
      ))
    }
  </div>

  <!-- Controles (Solo visibles en Móvil) -->
  <div class="flex md:hidden absolute z-30 -translate-x-1/2 bottom-2 left-1/2 space-x-3">
    {
      related_awards.map((_, index) => (
        <button
          type="button"
          class="w-2 h-2 rounded-full bg-gray-400 focus:bg-white"
          aria-label={`Slide ${index + 1}`}
          data-carousel-slide-to={index}
        ></button>
      ))
    }
  </div>

  <!-- Botones de Navegación (Opcional, ocultos en Desktop) -->
  <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group md:hidden" id="prevBtn">
    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-black/20 group-hover:bg-black/40 text-white">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
    </span>
  </button>
  <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group md:hidden" id="nextBtn">
    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-black/20 group-hover:bg-black/40 text-white">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
    </span>
  </button>
</div>
  </main>

  <script>
    window.addEventListener("scroll", () => {
      const heroImg = document.getElementById("hero-img");
      if (heroImg) {
        const scrollValue = window.scrollY;
        heroImg.style.transform = `translateY(${scrollValue * 0.2}px) scale(1.05)`;
      }
    });
    const wrapper = document.getElementById('carousel-wrapper');
  const items = document.querySelectorAll('[data-carousel-item]');
  const nextBtn = document.getElementById('nextBtn');
  const prevBtn = document.getElementById('prevBtn');
  let currentIndex = 0;

  function showItem(index) {
    if (window.innerWidth >= 768) return; // No hacer nada en desktop

    items.forEach((item, i) => {
      item.style.display = i === index ? 'flex' : 'none';
    });
  }

  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % items.length;
    showItem(currentIndex);
  });

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + items.length) % items.length;
    showItem(currentIndex);
  });

  // Inicializar vista móvil
  if (window.innerWidth < 768) {
    showItem(0);
  }
  </script>

  <style>
    main {
      scroll-behavior: smooth;
    }
    /* Estilo para que el texto sea muy legible y elegante */
    :global(p) {
      letter-spacing: 0.015em;
    }
    /* Oculta la barra de desplazamiento en Chrome, Safari y Opera */
  div::-webkit-scrollbar {
    display: none;
  }
  /* Oculta la barra de desplazamiento en IE, Edge y Firefox */
  div {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  </style>
</BaseLayout>