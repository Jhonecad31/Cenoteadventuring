---
import { getI18N } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagH2 from "@/components/global/TagH2.astro";
import TagH3 from "@/components/global/TagH3.astro";
import TagP from "@/components/global/TagP.astro";
import BContainer from "@/components/global/BContainer.astro";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
const cloudEndpoint = "https://ik.imagekit.io/pos7v26vx";
const images = {
  imgCenote: "/Cenote-Adventuring/CenoteA.6.webp", 
};
const getUrl = (id: string, w = 800) =>
  `${cloudEndpoint}/tr:w-${w},q-80,f-auto/${id}`;

---

<BaseLayout>
  <main class="bg-[#F8FAFC] overflow-x-hidden">
    
    <section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
      <img
        src={getUrl(images.imgCenote)}
        class="absolute z-0 w-full h-full object-cover scale-[1.05] brightness-[0.2]"
        id="hero-img"
        alt="Cenote Background"
        loading="eager"
      />

      <div class="relative z-10 text-center text-white px-6">
        <h1 class="font-serif italic text-4xl md:text-4xl mb-6 tracking-tight drop-shadow-lg">
          {i18n.ABOUT_US_PAGE.HERO.H1}
        </h1>
        <p class="tracking-[0.6em] font-light text-xs md:text-sm animate-fade-in opacity-90 mx-auto max-w-4xl">
          {i18n.ABOUT_US_PAGE.HERO.DESCRIPTION}
        </p>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto py-24 px-6">
      <BContainer>
        <div class="grid lg:grid-cols-12 gap-16 items-start">
          
          <div class="lg:col-span-5 space-y-6">
            <TagH2 class="font-serif italic text-5xl text-[#006083] leading-tight">
              {i18n.ABOUT_US_PAGE.MISSION.TITLE}
            </TagH2>
            <div class="w-16 h-[1px] bg-[#006083] opacity-30"></div>
            <TagP class="text-lg leading-relaxed text-slate-600 italic">
              "{i18n.ABOUT_US_PAGE.MISSION.STATEMENT}"
            </TagP>
          </div>

          <div class="lg:col-span-7 space-y-8">
            <div class="space-y-6 text-slate-700 leading-relaxed">
               <TagP>{i18n.ABOUT_US_PAGE.HERO.DESCRIPTION}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.HERO.ORIGIN_STORY}</TagP>
               <TagP>{i18n.ABOUT_US_PAGE.MISSION.PHILOSOPHY}</TagP>
            </div>

            <div class="pt-10 border-t border-slate-200">
               <TagH3 class="font-serif text-2xl text-[#006083] mb-6 uppercase tracking-widest">
                 {i18n.ABOUT_US_PAGE.FEATURES.H2}
               </TagH3>
               <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                 {i18n.ABOUT_US_PAGE.FEATURES.ITEMS.map((item: string) => (
                   <li class="flex items-center gap-3 text-xs uppercase tracking-widest text-slate-500 font-medium">
                     <span class="size-1.5 bg-[#006083] rounded-full"></span>
                     {item}
                   </li>
                 ))}
               </ul>
            </div>
          </div>

        </div>
      </BContainer>
    </section>

    <section class="bg-white py-24 border-y border-slate-100">
      <div class="max-w-[800px] mx-auto px-6 text-center space-y-8">
        <TagH2 class="font-serif italic text-4xl text-[#006083]">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.H2}
        </TagH2>
        <TagP class="text-slate-600 leading-loose">
          {i18n.ABOUT_US_PAGE.DESTINATION_INFO.CONTENT}
        </TagP>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left pt-10">
           {i18n.ABOUT_US_PAGE.HIGHLIGHTS.KEY_POINTS.map((point: string) => (
             <div class="border-l border-[#006083]/20 pl-4 py-2">
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#006083] mb-1">Highlight</p>
                <p class="text-sm text-slate-500">{point}</p>
             </div>
           ))}
        </div>
      </div>
    </section>

  </main>

  <script>
    window.addEventListener("scroll", () => {
      const heroImg = document.getElementById("hero-img");
      if (heroImg) {
        const scrollValue = window.scrollY;
        heroImg.style.transform = `translateY(${scrollValue * 0.2}px) scale(1.05)`;
      }
    });
  </script>

  <style>
    main {
      scroll-behavior: smooth;
    }
    /* Estilo para que el texto sea muy legible y elegante */
    :global(p) {
      letter-spacing: 0.015em;
    }
  </style>
</BaseLayout>