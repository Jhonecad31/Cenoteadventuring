---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Maps from "@/components/segments/Maps.astro"
import {
  Mail,
  Phone,
  Instagram,
  Facebook,
  Compass,
  MapPin,
  MessageSquare,
} from "lucide-react";
import TagH1 from "../global/TagH1.astro";
import { getI18N } from "@/i18n";
import TagP from "../global/TagP.astro";
import FormContact from "../others/FromContact";
import { Trip } from "@/icons/allIcons";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });

const { HERO, INFO, FORM } = i18n.CONTACT_PAGE;

const contactInfo = [
  {
    icon: Phone,
    title: INFO.OPTIONS.PHONE,
    value: "+52 998 249 0003",
    href: "tel:+529982490003",
  },
  {
    icon: Mail,
    title: INFO.OPTIONS.EMAIL,
    value: "info@cenoteadventuring.com",
    href: "mailto:info@cenoteadventuring.com",
  },
];

const socialMedia = [
  {
    title: "Instagram",
    icon: Instagram,
    link: "https://www.instagram.com/cenoteadventuring/",
  },
  {
    title: "Facebook",
    icon: Facebook,
    link: "https://www.facebook.com/cenoteadventuring/",
  },
  { title: "TripAdvisor", icon: Compass, link: "#" },
];

const seoMetaData = {
  title: i18n.SEO.CONTACT_PAGE.TITLE,
  description: i18n.SEO.CONTACT_PAGE.DESCRIPTION,
  metaTitle: i18n.SEO.CONTACT_PAGE.META_TITLE,
};
---

<BaseLayout {...seoMetaData}>
  <main class="bg-[#EDF4FC] pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">      
      <!-- HERO SECTION -->
      <div class="text-center mb-16">
        <TagH1 class="pt-20 max-w-3xl mx-auto px-5 font-serif text-center! md:text-4xl">
        {HERO.TITLE}
      </TagH1>
        <TagP class="text-[#001524]/60 max-w-4xl mx-auto mb-10 md:mb-20 !text-center px-5 lg:text-lg md:text-2xl">
          {HERO.DESCRIPTION}
        </TagP>
      </div>

      <!-- CONTACT GRID -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start mb-20">
        <!-- LEFT COLUMN: INFO & SOCIAL -->
        <div class="lg:col-span-5 space-y-8">
          <div class="bg-[#006083] text-white p-6 md:p-10 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
            <MessageSquare
              className="absolute -right-6 -top-6 w-24 h-24 md:-right-10 md:-top-10 md:w-40 md:h-40 opacity-10"
            />

            <h2 class="font-serif text-2xl md:text-3xl mb-8 relative z-10 text-center">
              {INFO.TITLE}
            </h2>

            <div class="space-y-6 md:space-y-8 relative z-10">
              {contactInfo.map((item) => (
                <div class="flex items-center lg:items-start gap-4">
                  <div class="p-3 bg-white/10 rounded-2xl shrink-0">
                    <item.icon size={24} className="text-cyan-400" />
                  </div>

                  <div class="min-w-0">
                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest opacity-60 mb-1">
                      {item.title}
                    </p>
                    <a href={item.href} class="text-base md:text-lg font-medium hover:text-cyan-400 transition-colors break-words block">
                      {item.value}
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- SOCIAL MEDIA CARD -->
          <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm flex items-center justify-between">
            <p class="font-medium text-[#001524]">{HERO.FOLLOW}</p>
            <ul class="flex gap-3">
              {socialMedia.map(({ title, icon: Icon, link }) => (
                <li>
                  <a
                    href={link}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={title}
                    class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-500 hover:bg-[#001524] hover:text-white transition-all duration-300 shadow-sm"
                  >
                    <Icon size={18} strokeWidth={1.5} />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- RIGHT COLUMN: FORM -->
        <div class="lg:col-span-7 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-gray-100">
          <FormContact
            client:visible
            i18n={i18n.CONTACT_PAGE.FORM}
            TITLE_FORM={i18n.CONTACT_PAGE.INFO.TITLE}
          />
        </div>
      </div>

      <!-- MAP SECTION: INTEGRATED DESIGN -->
      <section class="relative">
        <div class="flex items-center gap-4 mb-8">
           <div class="p-2 bg-[#006083] rounded-lg">
             <MapPin size={20} className="text-white" />
           </div>
           <h3 class="font-serif text-2xl text-[#001524]">Nuestra Ubicación</h3>
        </div>

        <div class="relative group">
          <!-- Efecto de borde brillante sutil al hacer hover -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-[#006083] to-cyan-500 rounded-[2.5rem] opacity-10 group-hover:opacity-20 blur transition duration-500"></div>
          
          <div class="relative bg-white p-3 rounded-[2.5rem] shadow-xl border border-gray-100 overflow-hidden h-[500px] md:h-[600px]">
            <div class="w-full h-full rounded-[1.8rem] overflow-hidden">
               <Maps />
            </div>
          </div>
        </div>

        <!-- INDICACIÓN DE RUTA -->
        <div class="mt-8 text-center md:text-left">
           <p class="text-sm text-[#001524]/50 italic">
             * Leona Vicario KM 19.1, 77580 Puerto Morelos, Q.R. — A 20 minutos de Cancún.
           </p>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>