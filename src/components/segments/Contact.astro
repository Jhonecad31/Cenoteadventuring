---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  Mail,
  Phone,
  Send,
  MessageSquare,
  Instagram,
  Facebook,
  Compass,
} from "lucide-react";
import TagH1 from "../global/TagH1.astro";
import { getI18N } from "@/i18n";
import TagP from "../global/TagP.astro";
import FormContact from "../others/FromContact";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });

const { HERO, INFO, FORM } = i18n.CONTACT_PAGE;

const contactInfo = [
  {
    icon: Phone,
    title: INFO.OPTIONS.PHONE,
    value: "+52 998 249 0003",
    href: "tel:+529982490003",
  },
  {
    icon: Mail,
    title: INFO.OPTIONS.EMAIL,
    value: "info@cenoteadventuring.com",
    href: "mailto:info@cenoteadventuring.com",
  },
];

const socialMedia = [
  {
    title: "Instagram",
    icon: Instagram,
    link: "https://www.instagram.com/cenoteadventuring/",
  },
  {
    title: "Facebook",
    icon: Facebook,
    link: "https://www.facebook.com/cenoteadventuring/",
  },
  { title: "TripAdvisor", icon: Compass, link: "#" },
];

const seoMetaData = {
  title: i18n.SEO.CONTACT_PAGE.TITLE,
  description: i18n.SEO.CONTACT_PAGE.DESCRIPTION,
  metaTitle: i18n.SEO.CONTACT_PAGE.META_TITLE,
};
---

<BaseLayout showFooter={currentLocale === "es"} {...seoMetaData}>
  <main class="bg-[#EDF4FC] pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <TagH1>{HERO.TITLE}</TagH1>
        <TagP
          class="text-[#001524]/60 max-w-4xl mx-auto mb-10 md:mb-20 text-center! px-5 lg:text-lg md:text-2xl"
        >
          {HERO.DESCRIPTION}
        </TagP>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 space-y-8">
          <div
            class="bg-[#006083] text-white p-6 md:p-10 rounded-[2rem] md:rounded-[2.5rem] shadow-2xl relative overflow-hidden"
          >
            <MessageSquare
              className="absolute -right-6 -top-6 w-24 h-24 md:-right-10 md:-top-10 md:w-40 md:h-40 opacity-10"
            />

            <h2
              class="font-serif text-2xl md:text-3xl mb-6 md:mb-8 relative z-10 text-center"
            >
              {INFO.TITLE}
            </h2>

            <div class="space-y-6 md:space-y-8 relative z-10">
              {
                contactInfo.map((item) => (
                  <div class="flex items-center lg:items-start gap-4">
                    <div class="p-2.5 md:p-3 bg-white/10 rounded-xl md:rounded-2xl shrink-0">
                      <item.icon
                        size={20}
                        className="text-cyan-400 md:w-6 md:h-6"
                      />
                    </div>

                    <div class="min-w-0">
                      {" "}
                      <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest opacity-60 mb-0.5 md:mb-1">
                        {item.title}
                      </p>
                      <a
                        href={item.href}
                        class="text-base md:text-lg font-medium hover:text-cyan-400 transition-colors break-words block"
                      >
                        {item.value}
                      </a>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div
            class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm flex items-center justify-between"
          >
            <p class="font-normal text-[#001524]">Follow our adventures:</p>
            <ul class="flex gap-3">
              {
                socialMedia.map(({ title, icon: Icon, link }) => (
                  <li key={title}>
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={title}
                      class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-500 hover:bg-[#001524] hover:text-white transition-all duration-300"
                    >
                      <Icon size={18} strokeWidth={1.5} />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <div
          class="lg:col-span-7 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-gray-100"
        >
          <FormContact
            client:visible
            i18n={i18n.CONTACT_PAGE.FORM}
            TITLE_FORM={i18n.CONTACT_PAGE.INFO.TITLE}
          />
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
