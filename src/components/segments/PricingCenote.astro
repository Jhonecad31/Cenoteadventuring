---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Star } from "lucide-react";
import { getI18N } from "@/i18n";
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const tour = {
  title: "Cenote adventuring",
  tagline:
    "Exclusive Experience at 3 Private Cenotes with a Mayan Show and Snacks",
  rating: 4.8,
  reviews: 1982,
  description:
    "Cenote Adventuring® is part of Grupo Extreme®, which offers five of Mexico's most award-winning and highly rated culinary and adventure experiences.",
  inclusions: [
    { text: "Conservation Fee (Included)", inc: true },
    { text: "Round-trip transportation", inc: true },
    { text: "3 Cenotes (Waterfall, Zipline, Cavern)", inc: true },
    { text: "Tequila Tasting", inc: true },
    { text: "Mayan Snack", inc: true },
    { text: "Mayan Performance", inc: false },
    { text: "Professional Photography", inc: false },
  ],
};

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

const carouselImages = [
  "CenoteA.1_ntnmsp",
  "CenoteA.2_njvbos",
  "CenoteA.3_pzncr9",
  "CenoteA.4_tevpif",
  "CenoteA.5_tdhqvl",
  "CenoteA.6_ikzdny",
  "CenoteA.7_rpyhjn",
  "CenoteA.8_jx4f49",
];
const relatedActivities = [
  {
    name: "Taco Tour",
    image: "taco_taco_ud62mv",
    slug: "beach-taco-tour",
  },
  {
    name: "Extreme Adventuring",
    image: "moto_moto_jxf9jy",
    slug: "extreme-adventuring",
  },
  {
    name: "Snorkel Adventuring",
    image: "snorkel_snorkel_iqkdev",
    slug: "snorkel-adventuring",
  },
];

const getUrl = (id: string, w = 1200) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;
---

<BaseLayout>
  <main class="bg-[#EDF4FC] pb-20 overflow-x-hidden">
    <section class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-7 flex flex-col gap-4 mt-23">
          <div
            class="relative group aspect-square md:aspect-[2/2] w-full overflow-hidden bg-gray-100 shadow-sm md:border md:border-gray-200 md:rounded-lg"
          >
            <button
              id="prev-btn"
              class="absolute left-4 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/60 hover:bg-white transition-all opacity-0 group-hover:opacity-100 shadow-sm"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-5 h-5 text-gray-700"
                ><path d="m15 18-6-6 6-6"></path></svg
              >
            </button>

            <img
              id="main-image"
              src={getUrl(carouselImages[0], 1200)}
              class="w-full h-full object-cover transition-all duration-500 hover:scale-105"
              alt={tour.title}
            />

            <button
              id="next-btn"
              class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/60 hover:bg-white transition-all opacity-0 group-hover:opacity-100 shadow-sm"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-5 h-5 text-gray-700"
                ><path d="m9 18 6-6-6-6"></path></svg
              >
            </button>
          </div>

          <div
            class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide mt-1 rounded-md"
          >
            {
              carouselImages.map((imgId, index) => (
                <button
                  class="thumbnail-btn min-w-[80px] h-[100px] border-2 border-transparent hover:border-[#006083] transition-all overflow-hidden"
                  data-index={index}
                  data-img={getUrl(imgId, 1200)}
                >
                  <img
                    src={getUrl(imgId, 200)}
                    class="w-full h-full object-cover"
                    alt={`View ${index + 1}`}
                  />
                </button>
              ))
            }
          </div>
        </div>

        <div class="lg:col-span-5 flex flex-col mt-25">
          <nav
            class="text-xs uppercase tracking-widest text-gray-400 mb-4 flex items-center gap-2"
          >
            <span class="text-gray-600">{tour.title}</span>
          </nav>

          <h1
            class="font-serif text-3xl md:text-4xl text-[#001524] leading-tight mb-2"
          >
            {tour.title}
          </h1>

          <div class="flex items-center gap-2 mb-6">
            <div class="flex">
              {
                [...Array(5)].map((_, i) => (
                  <Star
                    key={i}
                    size={16}
                    className={
                      i < 4.5
                        ? "fill-yellow-400 text-yellow-400"
                        : "text-gray-300"
                    }
                  />
                ))
              }
            </div>
            <span class="text-sm text-gray-500">{tour.reviews} Reviews</span>
          </div>

          <p class="text-2xl font-light text-gray-800 mb-8">
            $149.00 USD <span class="text-sm text-gray-400 font-normal"
              >per person</span
            >
          </p>

          <div class="space-y-6 mb-8">
            <div>
              <label
                class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-2"
              >
                Experience Type:
              </label>
              <select
                class="w-full border border-gray-300 p-3 text-sm focus:outline-none focus:border-[#006083] bg-white"
              >
                <option>Standard Experience</option>
                <option>Private Tour (+ $50)</option>
                <option>VIP Access (+ $120)</option>
              </select>
            </div>

            <div>
              <label
                class="block text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-2"
              >
                Group Size:
              </label>
              <select
                class="w-full border border-gray-300 p-3 text-sm focus:outline-none focus:border-[#006083] bg-white"
              >
                <option>1-4 People</option>
                <option>5-10 People</option>
                <option>Large Group (10+)</option>
              </select>
            </div>
          </div>

          <button
            class="w-full bg-[#006083] hover:bg-[#006083] text-white py-4 font-bold tracking-widest uppercase transition-colors mb-6 shadow-sm"
          >
            Add to Cart
          </button>

          <section>
            <button
              type="button"
              class="label collapsible-trigger collapsible-trigger-btn collapsible-trigger-btn--borders collapsible--auto-height is-open"
              aria-controls="Product-content-description9639832060234"
              aria-expanded="true"
            >

              </span>
            </button>
          </section>
        </div>
      </div>
    </section>
    <section>
      
    </section>
  </main>

  <style>
    @import "swiper/css";
    @import "swiper/css/pagination";
    .swiper-pagination-bullet-active {
      background: #005b71 !important;
    }

    .swiper-slide {
      opacity: 0.5;
      transition: opacity 0.3s ease;
    }

    .swiper-slide-active {
      opacity: 1;
    }

    @media (min-width: 1024px) {
      .swiper-slide {
        opacity: 1 !important;
        transform: scale(1) !important;
      }
    }
  </style>

  <script>
    function setupGallery() {
      const mainImg = document.getElementById("main-image") as HTMLImageElement;
      const thumbBtns = document.querySelectorAll(".thumbnail-btn");
      const prevBtn = document.getElementById("prev-btn");
      const nextBtn = document.getElementById("next-btn");

      if (!mainImg || thumbBtns.length === 0) return;
      const images = Array.from(thumbBtns).map((btn) =>
        btn.getAttribute("data-img"),
      );
      let currentIndex = 0;

      const updateGallery = (index: number) => {
        currentIndex = index;
        const newSrc = images[currentIndex];

        if (newSrc) {
          mainImg.src = newSrc;

          thumbBtns.forEach((btn, i) => {
            if (i === currentIndex) {
              btn.classList.add("border-[#006083]");
              btn.classList.remove("border-transparent");
            } else {
              btn.classList.remove("border-[#006083]");
              btn.classList.add("border-transparent");
            }
          });
        }
      };
      thumbBtns.forEach((btn, index) => {
        btn.addEventListener("click", () => updateGallery(index));
      });
      prevBtn?.addEventListener("click", () => {
        const newIndex =
          currentIndex === 0 ? images.length - 1 : currentIndex - 1;
        updateGallery(newIndex);
      });
      nextBtn?.addEventListener("click", () => {
        const newIndex = (currentIndex + 1) % images.length;
        updateGallery(newIndex);
      });
    }

    // Ejecución inicial y en cambios de página de Astro
    setupGallery();
    document.addEventListener("astro:page-load", setupGallery);
  </script>
</BaseLayout>
