---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  Star,
  Clock,
  Users,
  Calendar,
  Truck,
  Check,
  X,
  ChevronRight,
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { getI18N } from "@/i18n";
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
const tour = {
  title: "Cenote adventuring",
  tagline: "Exclusive Experience at 3 Private Cenotes with a Mayan Show and Snacks",
  rating: 4.8,
  reviews: 1982,
  description:
    "Cenote Adventuring® is part of Grupo Extreme®, which offers five of Mexico's most award-winning and highly rated culinary and adventure experiences.",
  inclusions: [
    { text: "Conservation Fee (Included)", inc: true },
    { text: "Round-trip transportation", inc: true },
    { text: "3 Cenotes (Waterfall, Zipline, Cavern)", inc: true },
    { text: "Tequila Tasting", inc: true },
    { text: "Mayan Snack", inc: true },
    { text: "Mayan Performance", inc: false },
    { text: "Professional Photography", inc: false },
  ],
};

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

const carouselImages = [
  "CenoteA.1_ntnmsp",
  "CenoteA.2_njvbos",
  "CenoteA.3_pzncr9",
  "CenoteA.4_tevpif",
  "CenoteA.5_tdhqvl",
  "CenoteA.6_ikzdny",
  "CenoteA.7_rpyhjn",
  "CenoteA.8_jx4f49",
];
const relatedActivities = [
  {
    name: "Taco Tour",
    image: "taco_taco_ud62mv",
    slug: "beach-taco-tour",
  },
  {
    name: "Extreme Adventuring",
    image: "moto_moto_jxf9jy",
    slug: "extreme-adventuring",
  },
  {
    name: "Snorkel Adventuring",
    image: "snorkel_snorkel_iqkdev",
    slug: "snorkel-adventuring",
  },
];

const getUrl = (id: string, w = 1200) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;
---

<BaseLayout>
  <main class="bg-[#EDF4FC] pb-20 overflow-x-hidden">
    <section class="pt-16 pb-8 px-6 text-center max-w-4xl mx-auto">
      <h1 class="font-serif lg:text-5xl md:text-6xl text-[#001524] mt-40">
        {tour.title}
      </h1>
      <p class="text-[#006083] font-medium mb-4 text-sm md:text-base">
        {tour.tagline}
      </p>
      <div class="flex items-center justify-center gap-2">
        <Star className="text-yellow-400 fill-yellow-400" size={20} />
        <span class="font-bold text-[#001524]">{tour.rating}</span>
        <span class="text-gray-600 text-sm">({tour.reviews} reviews)</span>
      </div>
    </section>

    <!-- Barra de info transportacion e intro -->
    <section class="max-w-4xl mx-auto px-6 mb-16 bg-[#EDF4FC]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
        <div class="relative h-[400px]">
          <div
            class="absolute top-0 left-0 w-2/3 h-4/5 overflow-hidden shadow-xl z-0"
          >
            <img
              src={getUrl("Gallery.9_amkmkc", 600)}
              class="w-full h-full object-cover"
            />
          </div>
          <div
            class="absolute bottom-0 right-0 w-2/3 h-4/5 overflow-hidden shadow-xl z-10"
          >
            <img
              src={getUrl("Gallery.1_w0aaof", 600)}
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <div class="text-center md:text-left">
          <h2 class="font-serif text-2xl italic text-[#001524] mb-6">
            Mexico's Most Awarded Adventure Company
          </h2>
          <hr class="border-gray-300 mb-6" />
          <p class="text-gray-600 leading-relaxed italic">
            "{tour.description}"
          </p>
          <hr class="border-gray-300 mt-6" />
        </div>
      </div>

      <div
        class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 grid grid-cols-2 md:grid-cols-4 gap-6 mb-12"
      >
        <div class="flex flex-col items-center text-center gap-2">
          <Clock size={30} className="text-gray-400" />
          <div>
            <p class="text-[10px] font-bold uppercase">
              Duration
            </p>
            <p class="text-xs font-semibold text-gray-400">4 hours approx</p>
          </div>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <Users size={30} className="text-gray-400" />
          <div>
            <p class="text-[10px] font-bold uppercase">
              Min. Age
            </p>
            <p class="text-xs font-semibold text-gray-400">5 years and older</p>
          </div>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <Calendar size={30} className="text-gray-400" />
          <div>
            <p class="text-[10px] font-bold uppercase">
              Schedule
            </p>
            <p class="text-xs font-semibold text-gray-400">09:00 | 13:00</p>
          </div>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <Truck size={30} className="text-gray-400" />
          <div>
            <p class="text-[10px] font-bold uppercase">
              Transportation
            </p>
            <p class="text-xs font-semibold text-gray-400">Round-trip included</p>
          </div>
        </div>
      </div>

      <div class="mb-20">
        <h3
          class="font-bold text-[#001524] mb-6 underline decoration-cyan-500 underline-offset-8"
        >
          Inclusions:
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4">
          {
            tour.inclusions.map((item) => (
              <div class="flex items-start gap-3">
                {item.inc ? (
                  <Check
                    size={18}
                    className="text-emerald-500 shrink-0 mt-0.5"
                  />
                ) : (
                  <X size={18} className="text-red-400 shrink-0 mt-0.5" />
                )}
                <span
                  class={`text-sm ${item.inc ? "text-gray-700" : "text-gray-400"}`}
                >
                  {item.text}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </section>
    <section class="bg-white py-20 px-6 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl text-[#001524] mb-4">
          {i18n.REGULAR_CENOTE?.INTRO?.TITLE}
        </h2>
        <p class="text-gray-500 max-w-2xl mx-auto">
          {i18n.REGULAR_CENOTE?.INTRO?.DESCRIPTION}
        </p>
      </div>

      <div class="swiper mySwiper pb-12">
        <div class="swiper-wrapper">
          {
            relatedActivities.map((activity) => (
              <div class="swiper-slide">
                <a href={`/activities/${activity.slug}/`} class="group block">
                  <div class="aspect-[3/4] overflow-hidden mb-6 shadow-sm bg-gray-100">
                    <img
                      src={getUrl(activity.image, 600)}
                      alt={activity.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    />
                  </div>
                  <div class="text-left">
                    <h3 class="font-serif text-xl text-[#001524] mb-2">
                      {activity.name}
                    </h3>

                    <div class="text-[11px] font-bold tracking-widest lg:text-gray-400 md:text-[#001524] flex items-center gap-2">
                      Discover more <ChevronRight size={14} />
                    </div>
                  </div>
                </a>
              </div>
            ))
          }
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </section>
  </main>
</BaseLayout>

<style>
  @import "swiper/css";
  @import "swiper/css/pagination";
  .swiper-pagination-bullet-active {
    background: #005b71 !important;
  }

  .swiper-slide {
  opacity: 0.5;
  transition: opacity 0.3s ease;
}

.swiper-slide-active {
  opacity: 1;
}

/* NUEVO: En desktop (min-width: 1024px), todos los slides visibles deben ser opacos */
@media (min-width: 1024px) {
  .swiper-slide {
    opacity: 1 !important;
    transform: scale(1) !important; /* Por si también se veían pequeños */
  }
}
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, Keyboard, Pagination } from "swiper/modules";

  function initSwiper() {
    new Swiper(".mySwiper", {
      modules: [Pagination, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: { delay: 4000 },
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3, spaceBetween: 40 },
      },
    });
  }

  initSwiper();
  document.addEventListener("astro:page-load", initSwiper);
</script>
