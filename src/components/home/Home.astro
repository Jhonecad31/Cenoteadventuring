---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Schema } from "astro-seo-schema";
import { getI18N } from "@/i18n";
import { getLangFromUrl } from "@/i18n/utils";
import Hero from "@/components/segments/Hero.astro";
import Awars from "@/components/segments/Awards.astro";
import PricingCardsHome from "@/components/segments/PricingCardsHome.astro"
import Gallery from "@/components/segments/Gallery.astro";
import Questions from "@/components/segments/Questions.astro";
import Awards from "@/pages/awards.astro";
import GalleryMovil from "@/components/segments/GalleryMovil.astro"
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
const lang = getLangFromUrl(Astro.url);

const seoMetaData = { 
    title: i18n.SEO.HOME_PAGE.TITLE,
    description: i18n.SEO.HOME_PAGE.DESCRIPTION,
    metaTitle: i18n.SEO.HOME_PAGE.META_TITLE, 
}
---
<BaseLayout seo={seoMetaData}>
    {i18n.HOME_PAGE.FAQS.FAQS && (
        <Schema
            slot="schema-jsonld"
            item={{
                "@context": "https://schema.org",
                "@type": "FAQPage",
                mainEntity: i18n.HOME_PAGE.FAQS.FAQS.map((faq: { question: any; answer: any; }) => ({
                    "@type": "Question",
                    name: faq.question,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: faq.answer,
                    },
                })),
            }}
        />
    )}
    <Hero />
    <Awards/>
    <PricingCardsHome />
    <Gallery />
    <Questions />
</BaseLayout>