---
import { getI18N } from "@/i18n";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@/i18n/utils";
import { Facebook, Instagram, Tripadvaisor} from "@/icons/allIcons";
import { CenoteAdventure } from "@/icons/allIcons";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const lang = getLangFromUrl(Astro.url);
const k = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentYear = new Date().getFullYear();
const navFooter = [

    {
        title: k("nav.home"),
        link: translatePath("/"),
    },
    {
        title: "Blog",
        link: "/blog/",
    },
    {
        title: k("nav.cenoteTrail"),
        link: translatePath("/cenote-trail/"),
    },
    {
        title: k("nav.activities"),
        link: translatePath("/activities/"),
    },
    {
        title: k("nav.contact"),
        link: translatePath("/Contact/contact/"),
    },
];

import {
  Phone,
  Mail,
  Instagram,
  Facebook,
  Tripadvisor,
Accessibility,
} from "lucide-react";

const socialMedia = [
  {
    title: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_FACEBOOK,
    icon: Facebook,
    link: "https://www.facebook.com/cenoteadventuring/"
  },
  {
    litle: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_FACEBOOK,
    icon: Instagram,
    link: "https://www.instagram.com/cenoteadventuring/"
  }
]
---

<footer class="bg-[#006083] text-white py-16 px-8 mt-auto w-full border-t border-white/10">
  <div class="max-w-[1800px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-24">
    
    <div class="flex flex-col gap-6">
      <h3 class="font-serif text-xl md:text-3xl lg:text-xl tracking-[0.2em] uppercase border-b border-white/10 pb-4 w-fit">
        Contact Us
      </h3>

      <div class="space-y-4 md:space-y-6 w-full">
        {/* Teléfono */}
        <div class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300">
          <div class="bg-white text-[#006083] p-2.5 md:p-4 rounded-full shadow-lg shrink-0">
            <Phone size={24} className="md:w-8 md:h-8 lg:w-5 lg:h-5" fill="currentColor" strokeWidth={0} />
          </div>
          <a href="tel:+529982998131" class="text-sm md:text-2xl lg:text-sm tracking-[0.15em] font-medium">
            +52 9982 99 81 31
          </a>
        </div>

        {/* Emails */}
        <div class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300">
          <div class="bg-white text-[#005B71] p-2.5 md:p-4 rounded-full shadow-lg shrink-0">
            <Mail size={24} className="md:w-8 md:h-8 lg:w-5 lg:h-5" fill="currentColor" strokeWidth={0} />
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[9px] md:text-lg lg:text-[9px] uppercase opacity-60 tracking-[0.2em]">For reservations:</span>
            <a href="mailto:reservas@grupo-extreme.com" class="text-xs md:text-2xl lg:text-xs hover:underline underline-offset-4">reservas@grupo-extreme.com</a>
          </div>
        </div>

        <div class="border border-white/20 p-5 md:p-8 flex items-center gap-6 hover:bg-white/5 transition-all duration-300">
          <div class="bg-white text-[#006083] p-2.5 md:p-4 rounded-full shadow-lg shrink-0">
            <Mail size={24} className="md:w-8 md:h-8 lg:w-5 lg:h-5" fill="currentColor" strokeWidth={0} />
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[9px] md:text-lg lg:text-[9px] uppercase opacity-60 tracking-[0.2em]">For corporate inquiries:</span>
            <a href="mailto:info@extremeadventuringcancun.com" class="text-xs md:text-2xl lg:text-xs hover:underline underline-offset-4">info@extremeadventuringcancun.com</a>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-6 lg:items-center">
      <div class="w-full lg:w-fit">
        <h3 class="font-serif text-xl md:text-3xl lg:text-xl tracking-[0.2em] uppercase border-b border-white/10 pb-4 w-fit">
          About
        </h3>
        <nav class="mt-6 md:mt-10">
          <ul class="flex flex-col gap-4 md:gap-6 text-[11px] md:text-2xl lg:text-[11px] uppercase tracking-[0.3em] font-light">
            {navFooter.map((item) => (
              <li><a href={item.link} class="hover:opacity-60 transition-opacity">{item.title}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </div>

    <div class="flex flex-col gap-6 lg:items-end relative md:relative lg:relative">
      <div class="w-full lg:w-fit flex flex-col lg:items-end">
        <h3 class="font-serif text-xl md:text-3xl lg:text-xl tracking-[0.2em] uppercase border-b border-white/10 pb-4 w-fit">
          Follow Us
        </h3>
        <ul class="flex flex-col gap-6 md:gap-10 mt-6 md:mt-10 text-[11px] md:text-2xl lg:text-[11px] uppercase tracking-[0.2em] font-medium lg:items-end z-10 relative">
          <li>
            <a href="#" class="flex items-center gap-4 group">
              Facebook <Facebook size={24} className="md:w-8 md:h-8 lg:w-5 lg:h-5 group-hover:scale-110 transition-transform" />
            </a>
          </li>
          <li>
            <a href="#" class="flex items-center gap-4 group">
              Instagram <Instagram size={24} className="md:w-8 md:h-8 lg:w-5 lg:h-5 group-hover:scale-110 transition-transform" />
            </a>
          </li>
        </ul>
      </div>

      <div class="absolute right-0 bottom-0 md:-bottom-4 lg:-right-4 lg:-bottom-4 opacity-90 z-0 pointer-events-none">
        <CenoteAdventure class="h-20 md:h-35 lg:h-18 w-auto p-1" />
      </div> 
    </div>
  </div>

  <div class="max-w-[1800px] mx-auto mt-20 pt-10 border-t border-white/10 flex flex-col lg:flex-row justify-between items-center gap-10 md:gap-14">
    <div class="text-[9px] md:text-xl lg:text-[9px] uppercase tracking-[0.3em] text-white/50 text-center lg:text-left leading-loose order-2 lg:order-1">
      <p>© {currentYear} Cenote Adventuring Cancun. All Rights Reserved.</p>
      <p class="mt-3 md:mt-5 lg:mt-2 text-white/30">Design By Grupo Extreme</p>
    </div>

    <div class="flex flex-wrap justify-center gap-6 md:gap-12 lg:gap-10 text-[10px] md:text-xl lg:text-[9px] uppercase tracking-[0.3em] text-white/50 order-1 lg:order-2 font-medium">
      <a href="#" class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1">Privacy Policy</a>
      <a href="#" class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1">Terms of Service</a>
      <a href="#" class="hover:text-white transition-colors border-b border-transparent hover:border-white/20 pb-1">Cookies Settings</a>
    </div>
  </div>
</footer>