---
const premios = {
  natgeo: "Premios_laureles-07_2_i2l2kl",
  world: "Premios_laureles-05_1_e3pfdg",
  TripA: "Premios_laureles-06_2_nvux3d",
};

const logosCloudinary = Object.values(premios);
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

const getUrl = (id: string, w = 400) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;
---

<section>
    <div class="md:mt-32 pt-12 w-full">
      <div class="flex flex-row items-center justify-around gap-3 w-full max-w-xl mx-auto">
        {logosCloudinary.map((logoId) => (
          <div class="flex justify-center items-center w-1/2 -mt-55">
            <img
              src={getUrl(logoId)}
              alt="Distintivo de Premio con Laureles"
              class="md:h-8 w-auto transition-all duration-500" 
            />
          </div>
        ))}
      </div>
    </div>
</section>