---
import { getI18N } from "@/i18n";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@/i18n/utils";
import { Menu, X, Search, User, Phone, Facebook, Link } from "lucide-react"; // Añadimos Phone
import { Button } from "@/components/ui/button";
import LanguageSelector from "./LanguageSelector.astro";
import { CenoteAdventure } from "@/icons/allIcons";
import { keyof } from "astro:schema";

const { currentLocale } = Astro;
const { offI18n } = Astro.props;
const i18n = getI18N({ currentLocale }) as any;
const lang = getLangFromUrl(Astro.url);
const k = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navigation = [
  { title: k("nav.home"), link: translatePath("/") },
  {
    title: k("nav.cenoteTrail"),
    link: translatePath("sections/cenote-trail/"),
  },
  { title: k("nav.activities"), link: translatePath("/activities/") },
  { title: k("nav.blog"), link: translatePath("/blog/") },
  { title: k("nav.contact"), link: translatePath("/Contact/contact/") },
];
---

<header
  class="fixed top-0 w-full z-50 transition-all duration-500 h-24 flex items-center border-b border-transparent"
  id="main-header"
>
  <div
    class="max-w-[1800px] mx-auto px-6 md:px-20 w-full flex items-center justify-between h-full"
  >
    <div class="flex-1 lg:hidden">
      <button class="text-white transition-colors duration-500" id="open-menu">
        <Menu size={28} strokeWidth={1.2} />
      </button>
    </div>

    <div
      class="flex-[2] flex justify-center lg:flex-1 lg:justify-start lg:items-center"
    >
      <a
        href={translatePath("/")}
        aria-label={i18n.ACCESSIBILITY?.GO_TO_HOME}
        class="group block w-fit hover:scale-95 transition-transform duration-300"
      >
        <div
          id="logo-container"
          class="text-white transition-colors duration-500"
        >
          <CenoteAdventure
            class="h-16 md:h-20 p-1 transition-all duration-500"
            id="main-logo-svg"
          />
        </div>
      </a>
    </div>

    <nav class="hidden lg:block">
      <ul class="flex gap-10">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.link}
                class="nav-link text-[13px] uppercase tracking-[0.2em] text-white hover:opacity-60 transition-all font-medium"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex-1 flex items-center justify-end gap-5">
      <div
        class="flex items-center gap-5 text-withe transition-colors duration-500"
        id="icon-group"
      >
        {!offI18n && <LanguageSelector />}
      </div>
    </div>
  </div>

  <div
    id="mobile-drawer"
    class="fixed inset-0 bg-[#006083] z-[60] -translate-x-full transition-transform duration-500 ease-in-out flex flex-col p-10"
  >
    <div class="flex justify-end">
      <button id="close-menu" ...>
        <X size={35} strokeWidth={1} />
      </button>
    </div>
    <nav class="mt-20 text-center">
      <ul class="flex flex-col gap-10">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.link}
                class="font-serif text-4xl italic text-white block"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("main-header");
  const logoContainer = document.getElementById("logo-container");
  const logoSvg = document.getElementById("main-logo-svg");
  const iconGroup = document.getElementById("icon-group");
  const btnReserve = document.getElementById("btn-reserve");
  const navLinks = document.querySelectorAll(".nav-link");
  const openBtn = document.getElementById("open-menu");
  const closeBtn = document.getElementById("close-menu");
  const drawer = document.getElementById("mobile-drawer");
  const langSelector = document.getElementById("language-selector-container");

  window.addEventListener("scroll", () => {
    const isScrolled = window.scrollY > 20;

    langSelector?.classList.toggle("text-[#002B49]", isScrolled);
    langSelector?.classList.toggle("text-white", !isScrolled);

    // Fondo y Altura
    header?.classList.toggle("bg-[#EDF4FC]", isScrolled);
    header?.classList.toggle("shadow-sm", isScrolled);
    header?.classList.toggle("h-20", isScrolled);
    header?.classList.toggle("h-24", !isScrolled);

    // Color del Logo y Contenedor
    logoContainer?.classList.toggle("text-[#002B49]", isScrolled);
    logoContainer?.classList.toggle("text-white", !isScrolled);

    // Reducir tamaño del logo al hacer scroll
    if (isScrolled) {
      logoSvg?.classList.replace("md:h-20", "md:h-14");
    } else {
      logoSvg?.classList.replace("md:h-14", "md:h-20");
    }

    // Iconos y Links
    iconGroup?.classList.toggle("text-[#002B49]", isScrolled);
    iconGroup?.classList.toggle("text-white", !isScrolled);
    openBtn?.classList.toggle("text-[#002B49]", isScrolled);
    openBtn?.classList.toggle("text-white", !isScrolled);

    btnReserve?.classList.toggle("text-[#002B49]", isScrolled);
    btnReserve?.classList.toggle("border-[#002B49]/30", isScrolled);
    btnReserve?.classList.toggle("text-white", !isScrolled);
    btnReserve?.classList.toggle("border-white/30", !isScrolled);

    navLinks.forEach((link) => {
      link.classList.toggle("text-[#002B49]", isScrolled);
      link.classList.toggle("text-white", !isScrolled);
    });
  });

  // En tu script
  openBtn?.addEventListener("click", () => {
    drawer?.classList.remove("-translate-x-full"); // Quita el negativo
    document.body.style.overflow = "hidden";
  });

  closeBtn?.addEventListener("click", () => {
    drawer?.classList.add("-translate-x-full"); // Vuelve a esconder a la izquierda
    document.body.style.overflow = "";
  });
</script>
