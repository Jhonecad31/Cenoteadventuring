---
import { getI18N } from "@/i18n";
import Layout from "@/layouts/BaseLayout.astro";
import TagH1 from "@/components/global/TagH1.astro";
import TagH2 from "@/components/global/TagH2.astro";
import TagH3 from "@/components/global/TagH3.astro";
import TagP from "@/components/global/TagP.astro";
import BContainer from "@/components/global/BContainer.astro";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const videoId = import.meta.env.PUBLIC_CLOUDINARY_VIDEO_ID;

const videoUrl = `https://res.cloudinary.com/depikrkrz/video/upload/v1774544286/video_cenote_web_nzoauf.mp4`;
const posterUrl = `https://res.cloudinary.com/${cloudName}/video/upload/f_auto,q_auto/${videoId}.jpg`;

const seoMetaData = {
  title: i18n?.Selection?.ABOUT_US_PAGE?.TITLE || "Cenote Adventure",
  description: i18n?.SEO?.ABOUT_US_PAGE?.DESCRIPTION || "Default description",
};
---

<Layout seo={seoMetaData}>
  <main class="bg-[#EDF4FC] overflow-x-hidden">
    <section class="max-w-[1000px] mx-auto py-15 px-6 mt-25">
      <TagH2 class="font-serif italic text-5xl text-[#006083] text-center">{i18n.ABOUT_US_PAGE.INTRO.TITLE}</TagH2>
      <div class="w-12 h-[2px] bg-[#006083] mx-auto opacity-30"></div>
      <p class="text-center uppercase tracking-[0.3em] text-[10px] text-slate-500 font-bold">
        Un viaje visual por lo inexplorado
      </p>

      <!-- textos para our story cenotes -->
      <BContainer>
        <div class="mb-5 w-full lg:w-4/5 mx-auto">
           <TagP class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.DESCRIPTION_1}</TagP>
                <TagP class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.DESCRIPTION_2}</TagP>
                 <TagP class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.DESCRIPTION_3}</TagP>
                  <TagP class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.DESCRIPTION_4}</TagP>
                   <TagP class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.DESCRIPTION_5}</TagP>
                <TagH3 class="text-center text-[10px] text-black-500">{i18n.ABOUT_US_PAGE.INTRO.SUBTITLE_LIST}</TagH3>
                </TagH3>
                <div class="grid lg:grid-cols-5 items-center gap-5">
                    <div class="lg:col-span-3">
                        <TagP>{i18n.ABOUT_US_PAGE.OUR_STORY.TITLE_LIST}</TagP>
                        <ul
                            class="list-disc list-inside space-y-2 mt-4 text-sm/relaxed md:text-base/relaxed"
                        >
                        </ul>
                    </div>
                    </div>
                </div>
                <TagH3 class="text-center tracking-[0.3em] text-[10px] text-slate-500 font-bold"></TagH3>
            </div>
        </div>
      </BContainer>
    </section>
  </main>

  <script>
    // Efecto Parallax suave para el Hero
    window.addEventListener("scroll", () => {
      const heroImg = document.getElementById("hero-img");
      if (heroImg) {
        const scrollValue = window.scrollY;
        heroImg.style.transform = `translateY(${scrollValue * 0.3}px) scale(1.05)`;
      }
    });
  </script>

  <style>
    /* Personalización extra para el scroll de la página */
    main {
      scroll-behavior: smooth;
    }
  </style></Layout
>
