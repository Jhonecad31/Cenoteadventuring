---
import { getI18N } from "@/i18n";
import { Natgeo } from "@/icons/allIcons";
import Swiper from "swiper";
import { Autoplay } from "swiper/modules";
import TagH1 from "@/components/global/TagH1.astro";
import TagH2 from "@/components/global/TagH2.astro";
import TagH3 from "@/components/global/TagH3.astro";
import TagP from "@/components/global/TagP.astro";
const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const premios = {
  natgeo: "Premios_laureles-07_2_i2l2kl",
  world: "Premios_laureles-05_1_e3pfdg",
  TripA: "Premios_laureles-06_2_nvux3d",
};

const logosCloudinary = Object.values(premios);
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

const getUrl = (id: string, w = 1200) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;
---

<section class="bg-[#F8FAFC] py-24 md:py-40 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-start">
      <div class="max-w-md">
        <div class="w-12 h-[1px] bg-[#006083] mb-8"></div>
        <TagH1
          class="font-serif text-4xl md:text-5xl lg:text-6xl text-[#001524] leading-[1.1]"
        >
          {i18n.HOME_PAGE.AWARDS.TITLE}
        </TagH1>
      </div>

      <div class="flex flex-col gap-8 lg:mt-4">
        <TagP
          class="text-[#001524]/80 text-xl md:text-2xl leading-relaxed font-light font-serif regular!"
        >
          {i18n.HOME_PAGE.AWARDS.DESCRIPTION1}
        </TagP>

        <div
          class="space-y-6 text-[#001524]/70 text-lg leading-relaxed max-w-xl -mt-10"
        >
          <TagP>
            {i18n.HOME_PAGE.AWARDS.DESCRIPTION2}
          </TagP>

          <a
            href="/about"
            class="inline-block pt-4 text-[#005B71] uppercase tracking-[0.2em] text-xs font-bold border-b border-[#005B71]/20 hover:border-[#005B71] transition-all duration-300"
          >
            {i18n.HOME_PAGE.AWARDS.DESCRIP_LINK}
          </a>
        </div>
      </div>
    </div>
  </div>

 <div class="mt-20 md:mt-32 pt-16">
  <div class="swiper awards-swiper overflow-hidden md:overflow-visible">
    <div 
      class="swiper-wrapper flex items-center md:grid md:grid-cols-3 md:gap-12 md:!transform-none"
    >
      {
        Object.entries(premios).map(([key, id]) => (
          <div class="swiper-slide flex justify-center md:!w-full">
            <div class="relative group">
              <img
                src={getUrl(id, 400)}
                alt={`Premio ${key}`}
                class="h-20 md:h-28 w-auto object-contain transition-all duration-700"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
</section>

<style is:global>
  /* Estilo para que el movimiento sea lineal y fluido (estilo Marquee) */
  .myAwardsSwiper .swiper-wrapper {
    transition-timing-function: linear !important;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";
  import 'swiper/css';

  let swiperInstance = null;

  function initSwiper() {
    const breakpoint = window.matchMedia('(min-width: 768px)');
    const swiperContainer = document.querySelector('.awards-swiper');

    if (!swiperContainer) return;

    const enableSwiper = () => {
      swiperInstance = new Swiper('.awards-swiper', {
        modules: [Autoplay],
        slidesPerView: 1.5,
        spaceBetween: 20,
        centeredSlides: true,
        loop: true,
        autoplay: {
          delay: 2500,
          disableOnInteraction: false,
        },
      });
    };

    // Si la pantalla es pequeña y no hay instancia, crearla
    if (!breakpoint.matches && !swiperInstance) {
      enableSwiper();
    } 
    // Si la pantalla es grande y hay instancia, destruirla
    else if (breakpoint.matches && swiperInstance) {
      swiperInstance.destroy(true, true);
      swiperInstance = null;
    }
  }

  // Escuchar cambios de tamaño de ventana
  window.addEventListener('resize', initSwiper);

  // Inicializar al cargar
  initSwiper();
  
  // Compatibilidad con transiciones de Astro (View Transitions)
  document.addEventListener("astro:after-swap", initSwiper);
</script>
