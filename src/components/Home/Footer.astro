---
import { getI18N } from "@/i18n";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@/i18n/utils";
import {
  Phone,
  Mail,
  //Tripadvisor,
  Facebook,
  Instagram,
  Linkedin,
  Youtube,
Accessibility,
} from "lucide-react";
import { CenoteAdventure } from "@/icons/allIcons";
import type { navigate } from "astro:transitions/client";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
const lang = getLangFromUrl(Astro.url);
const k = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentYear = new Date().getFullYear();

const footerNav = [
  { title: k("nav.home"), link: translatePath("/") },
  { title: k("nav.cenoteTrail"), link: translatePath("/cenote-trail/")},
  { title: k("nav.activities"), link: translatePath("/activities/") },
  { title: k("nav.blog"), link: translatePath("/blog/")},
  { title: k("nav.contact"), link: translatePath("/Contact/contact/") }
];

const socialMedia = [
  // {
  //   titile: i18n.ACCESSIBILITY.SOCIAL_MEDIA,
  //   icon: Facebook,
  //   link: "https://www.facebook.com/cenoteadventuring", 
  // },
  // {
  //   title: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_INSTAGRAM,
  //   icon: Instagram,
  //   link: "https://www.instagram.com/cenoteadventuring/",
  // }
  // {
  //   title: i18n.ACCESSIBILITY.SOCIAL_MEDIA.GO_TO_TRIPADVISOR,
  //   icon: Tripadvisor,
  //   link: "https://www.tripadvisor.com/Attraction_Review-g150807-d28040463-Reviews-Snorkel_Adventuring-Cancun_Yucatan_Peninsula.html",
  // }
]
---

<footer
  class="bg-[#006083] text-white py-16 px-8 mt-auto w-full border-t border-white/10"
>
  <div
    class="max-w-[1800px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-16 lg:gap-24"
  >
    <div class="flex flex-col gap-6">
      <h3
        class="font-serif text-xl tracking-[0.2em] uppercase regular border-b border-white/10 pb-4 w-fit"
      >
        Contact Us
      </h3>

      <div class="space-y-4">
        <div
          class="border border-white/20 p-5 flex items-center gap-4 hover:bg-white/5 transition-all duration-300"
        >
          <div class="bg-white text-[#006083] p-2.5 rounded-full shadow-lg">
            <Phone size={18} fill="currentColor" strokeWidth={0} />
          </div>
          <a
            href="tel:+529982998131"
            class="text-sm tracking-[0.15em] font-medium">+52 9982 99 81 31</a
          >
        </div>

        <div
          class="border border-white/20 p-5 flex items-center gap-4 hover:bg-white/5 transition-all duration-300"
        >
          <div class="bg-white text-[#005B71] p-2.5 rounded-full shadow-lg">
            <Mail size={18} fill="currentColor" strokeWidth={0} />
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[9px] uppercase opacity-60 tracking-[0.2em]"
              >For reservations:</span
            >
            <a
              href="mailto:reservas@grupo-extreme.com"
              class="text-xs hover:underline decoration-white/30 underline-offset-4"
              >reservas@grupo-extreme.com</a
            >
          </div>
        </div>

        <div
          class="border border-white/20 p-5 flex items-center gap-4 hover:bg-white/5 transition-all duration-300"
        >
          <div class="bg-white text-[#006083] p-2.5 rounded-full shadow-lg">
            <Mail size={18} fill="currentColor" strokeWidth={0} />
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[9px] uppercase opacity-60 tracking-[0.2em]"
              >For corporate inquiries:</span
            >
            <a
              href="mailto:info@extremeadventuringcancun.com"
              class="text-xs hover:underline decoration-white/30 underline-offset-4"
              >info@extremeadventuringcancun.com</a
            >
          </div>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-12 text-center py-4"
    >
      <div class="flex flex-col items-center gap-6">
        <h3 class="font-serif text-xl tracking-[0.2em] uppercase regular">
          About
        </h3>
        <nav>
          <ul
            class="flex flex-col gap-4 text-[11px] uppercase tracking-[0.3em] font-light"
          >
            {
              footerNav.map((item) => (
                <li>
                  <a
                    href={item.link}
                    class="hover:opacity-60 transition-opacity"
                  >
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <div
        class="text-white opacity-90 hover:scale-105 transition-transform duration-500"
      >
        <CenoteAdventure class="h-28 w-auto p-2" />
      </div>
    </div>

    <div class="flex flex-col items-start md:items-end gap-8">
      <h3
        class="font-serif text-xl tracking-[0.2em] uppercase regular border-b border-white/10 pb-4 w-fit md:text-right"
      >
        Follow Us
      </h3>
      <ul
        class="flex flex-col gap-6 text-[11px] uppercase tracking-[0.2em] w-full md:items-end font-medium"
      >
        <li>
          <a href="#" class="flex items-center gap-4 group">
            Facebook <Facebook
              size={20}
              strokeWidth={1.2}
              className="group-hover:scale-110 transition-transform"
            />
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center gap-4 group">
            Instagram <Instagram
              size={20}
              strokeWidth={1.2}
              className="group-hover:scale-110 transition-transform"
            />
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center gap-4 group">
            X (Twitter) <span
              class="text-lg font-bold group-hover:scale-110 transition-transform"
              >X</span
            >
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center gap-4 group">
            LinkedIn <Linkedin
              size={20}
              strokeWidth={1.2}
              className="group-hover:scale-110 transition-transform"
            />
          </a>
        </li>
        <li>
          <a href="#" class="flex items-center gap-4 group">
            Youtube <Youtube
              size={20}
              strokeWidth={1.2}
              className="group-hover:scale-110 transition-transform"
            />
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div
    class="max-w-[1800px] mx-auto mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8"
  >
    <div
      class="text-[9px] uppercase tracking-[0.3em] text-white/50 text-center md:text-left leading-relaxed"
    >
      <p>© {currentYear} Cenote Adventuring Cancun. All Rights Reserved.</p>
      <p class="mt-2 text-white/30">Design By Grupo Extreme</p>
    </div>

    <div
      class="flex gap-10 text-[9px] uppercase tracking-[0.3em] text-white/50"
    >
      <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
      <a href="#" class="hover:text-white transition-colors">Terms of Service</a
      >
      <a href="#" class="hover:text-white transition-colors">Cookies Settings</a
      >
    </div>
  </div>
</footer>
