---
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselNext,
  CarouselPrevious,
} from "@/components/ui/carousel";
import { Card, CardContent } from "@/components/ui/card";

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

const galleryImages: string[] = [
  'Gallery.7.jpg', 'Gallery.1.jpg', 'Gallery.2.jpg', 
  'Gallery.3.jpg', 'Gallery.4.jpg', 'Gallery.8.jpg'
];

const getUrl = (id: string) => 
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_1000/${id}`;
---

<section class="py-24 bg-[#F4F7FA] overflow-hidden">
  <div class="max-w-7xl mx-auto px-12">
    
    {/* IMPORTANTE: client:load en la raíz. 
       Si el error persiste, usa client:only="react" 
    */}
    <Carousel 
      client:only="react" 
      opts={{ align: "center", loop: true }}
      className="w-full relative"
    >
      <CarouselContent className="-ml-2 md:-ml-4">
        {galleryImages.map((id) => (
          <CarouselItem key={id} className="pl-2 md:pl-4 md:basis-1/2 lg:basis-1/3">
            <div class="p-1">
              <Card className="border-none shadow-none bg-transparent">
                <CardContent className="flex aspect-[3/4] items-center justify-center p-0 overflow-hidden rounded-md shadow-sm">
                  <img 
                    src={getUrl(id)} 
                    alt="Cenote Adventure Gallery" 
                    class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                    loading="lazy"
                  />
                </CardContent>
              </Card>
            </div>
          </CarouselItem>
        ))}
      </CarouselContent>
      
      {/* Las flechas DEBEN estar físicamente aquí antes del cierre de Carousel */}
      <CarouselPrevious className="absolute -left-10 top-1/2 -translate-y-1/2" />
      <CarouselNext className="absolute -right-10 top-1/2 -translate-y-1/2" />
    </Carousel>

  </div>
</section>