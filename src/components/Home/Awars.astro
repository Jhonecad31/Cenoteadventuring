---
import { getI18N } from "@/i18n";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;
---

<section class="bg-white py-24 md:py-40 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-start">
      
      <div class="max-w-md">
        <div class="w-12 h-[1px] bg-[#005B71] mb-8"></div>
        
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-[#001524] regular leading-[1.1]">
          {i18n.HOME_PAGE?.DESCRIPTION?.TITLE || "Mexico’s Most Awarded Adventure Company"}
        </h2>
      </div>

      <div class="flex flex-col gap-8 lg:mt-4">
        <p class="text-[#001524]/80 text-xl md:text-2xl leading-relaxed font-light font-serif regular">
           {i18n.HOME_PAGE?.DESCRIPTION?.SUBTITLE || "Luxury meets the wilderness in the heart of the Riviera Maya."}
        </p>
        
        <div class="space-y-6 text-[#001524]/70 text-lg leading-relaxed max-w-xl">
          <p>
            {i18n.HOME_PAGE?.DESCRIPTION?.TEXT_1 || "Book your spot today to enjoy the highest-rated culinary and adventure experiences in the Mexican Caribbean. Paradise awaits."}
          </p>
          
          <a href="/about" class="inline-block pt-4 text-[#005B71] uppercase tracking-[0.2em] text-xs font-bold border-b border-[#005B71]/20 hover:border-[#005B71] transition-all duration-300">
            {i18n.HOME_PAGE?.DESCRIPTION?.LINK || "Discover our story"}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>