---
const faqs = [
  {
    question: "Does the tour include transportation to the cenote in Puerto Morelos?",
    answer: "Yes, we provide round-trip transportation from most hotels in Cancun and Riviera Maya. Our vehicles are air-conditioned and driven by certified guides."
  },
  {
    question: "How long is the experience?",
    answer: "The standard tour lasts approximately 4 hours, including transportation and the Mayan performance."
  }
];
---

<section class="py-24 bg-[#F8FAFC]">
  <div class="max-w-3xl mx-auto px-6">
    
    <div class="bg-white border border-gray-100 p-8 mb-20 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
      <p class="text-gray-700 text-sm font-medium">
        Do you have any questions or concerns? Our team is here to help.
      </p>
      <a href="/contact" class="bg-[#006083] hover:bg-[#006083] text-white px-8 flex items-center justify-center uppercase text-[10px] tracking-widest h-11 transition-colors">
        Contact Us
      </a>
    </div>

    <h2 class="font-serif text-3xl md:text-4xl text-[#001524] mb-12">
      Explore our FAQ section for answers on common questions
    </h2>

    <div class="divide-y divide-gray-200">
      {faqs.map((faq) => (
        <details class="group py-4 outline-none">
          <summary class="flex justify-between items-center cursor-pointer list-none py-4 text-left text-lg md:text-xl font-medium text-[#001524] hover:text-[#005B71] transition-colors">
            <span>{faq.question}</span>
            <span class="text-2xl font-light text-gray-400 transition-transform duration-300 group-open:rotate-45 block">
              +
            </span>
          </summary>
          <div class="pb-6 pr-12 text-gray-600 leading-relaxed animate-fade-in">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* Oculta la flecha por defecto de la lista en todos los navegadores */
  summary::-webkit-details-marker {
    display: none;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeIn 0.4s ease-out;
  }
</style>