---
// src/components/home/PricingCards.astro
import { Check } from "lucide-react";
import { Button } from "@/components/ui/button";
import { getI18N } from "@/i18n";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale }) as any;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "depikrkrz";

// Definimos los IDs de Cloudinary para las portadas
const images = {
  cenoteAdventuring: "Card.Pricing1.2_tmxm0r", 
  privateRental: "Card.Pricing1_jpwkph", 
  logoCenote: "logo-cenote_rscfb4", 
  logoPrivate: "logo-private_wd8kxq"
};

// Función para obtener la URL optimizada
const getUrl = (id: string, w = 800) =>
  `https://res.cloudinary.com/${cloudName}/image/upload/f_auto,q_auto,w_${w}/${id}`;
---

<section class="bg-[#F4F7FA] py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {/* TARJETA 1: CENOTE ADVENTURING */}
      <div
        class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 flex flex-col"
      >
        <div class="relative h-64 md:h-80">
          <img
            src={getUrl(images.cenoteAdventuring)}
            alt="Cenote Adventuring"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute bottom-4 left-4 bg-white/90 p-2 rounded-lg backdrop-blur-sm"
          >
            <img src={getUrl(images.logoCenote)} alt="Logo" class="h-10 w-auto" />
          </div>
        </div>

        <div
          class="p-8 flex flex-col md:flex-row gap-6 justify-between flex-grow"
        >
          <div class="flex-1">
            <h3 class="font-serif text-3xl text-[#001524] mb-2">
              Cenote Adventuring:
            </h3>
            <p class="text-gray-600 mb-1">3 cenote boutique</p>
            <p class="text-gray-600 mb-4 font-medium">
              Experience, Mayan Show with snack
            </p>
            <p class="text-[#005B71] font-bold mb-6">4 hours</p>

            <ul class="space-y-3">
              {
                [
                  "Cenote with Waterfall",
                  "Cenote with Cavern",
                  "Cenote with Zipline",
                  "Tequila tasting",
                  "Mayan performance",
                ].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-gray-700">
                    <Check size={16} className="text-gray-400" /> {item}
                  </li>
                ))
              }
            </ul>
          </div>

          <div
            class="w-full md:w-48 bg-gray-50/50 p-6 rounded-xl border border-gray-100 text-center flex flex-col justify-between"
          >
            <div>
              <p class="text-[10px] text-gray-400 line-through">
                Price from $80 USD
              </p>
              <div class="text-3xl font-bold text-[#001524]">$70 USD</div>
              <p class="text-[10px] text-gray-500 mb-4">per person</p>
            </div>

            <div class="grid grid-cols-2 gap-2 mb-6">
              <div class="bg-white p-2 rounded-lg border border-gray-100">
                <span
                  class="block text-[10px] font-bold text-white bg-[#005B71] rounded-full px-1 mb-1"
                  >10%</span
                >
                <p class="text-[8px] leading-tight text-gray-400">
                  Booking 15 days before
                </p>
                <p class="text-[10px] font-bold">$77 USD</p>
              </div>
              <div class="bg-white p-2 rounded-lg border border-gray-100">
                <span
                  class="block text-[10px] font-bold text-white bg-[#005B71] rounded-full px-1 mb-1"
                  >20%</span
                >
                <p class="text-[8px] leading-tight text-gray-400">
                  Booking 30 days before
                </p>
                <p class="text-[10px] font-bold">$60 USD</p>
              </div>
            </div>

            <Button
              className="w-full bg-[#005B71] hover:bg-[#004252] text-white rounded-full text-xs h-9"
            >
              Check Availability
            </Button>
          </div>
        </div>
      </div>

      {/* TARJETA 2: CENOTE PRIVATE */}
      <div
        class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 flex flex-col"
      >
        <div class="relative h-64 md:h-80">
          <img
            src={getUrl(images.privateRental)}
            alt="Cenote Adventuring"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute bottom-4 left-4 bg-white/90 p-2 rounded-lg backdrop-blur-sm"
          >
            <img src={getUrl(images.logoPrivate)} alt="Logo" class="h-10 w-auto" />
          </div>
        </div>

        <div
          class="p-8 flex flex-col md:flex-row gap-6 justify-between flex-grow"
        >
          <div class="flex-1">
            <h3 class="font-serif text-3xl text-[#001524] mb-2">
              Cenote Adventuring:
            </h3>
            <p class="text-gray-600 mb-1">3 cenote boutique</p>
            <p class="text-gray-600 mb-4 font-medium">
              Experience, Mayan Show with snack
            </p>
            <p class="text-[#005B71] font-bold mb-6">4 hours</p>

            <ul class="space-y-3">
              {
                [
                  "Cenote with Waterfall",
                  "Cenote with Cavern",
                  "Cenote with Zipline",
                  "Tequila tasting",
                  "Mayan performance",
                ].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-gray-700">
                    <Check size={16} className="text-gray-400" /> {item}
                  </li>
                ))
              }
            </ul>
          </div>

          <div
            class="w-full md:w-48 bg-gray-50/50 p-6 rounded-xl border border-gray-100 text-center flex flex-col justify-between"
          >
            <div>
              <p class="text-[10px] text-gray-400 line-through">
                Price from $80 USD
              </p>
              <div class="text-3xl font-bold text-[#001524]">$70 USD</div>
              <p class="text-[10px] text-gray-500 mb-4">per person</p>
            </div>

            <div class="grid grid-cols-2 gap-2 mb-6">
              <div class="bg-white p-2 rounded-lg border border-gray-100">
                <span
                  class="block text-[10px] font-bold text-white bg-[#005B71] rounded-full px-1 mb-1"
                  >10%</span
                >
                <p class="text-[8px] leading-tight text-gray-400">
                  Booking 15 days before
                </p>
                <p class="text-[10px] font-bold">$77 USD</p>
              </div>
              <div class="bg-white p-2 rounded-lg border border-gray-100">
                <span
                  class="block text-[10px] font-bold text-white bg-[#005B71] rounded-full px-1 mb-1"
                  >20%</span
                >
                <p class="text-[8px] leading-tight text-gray-400">
                  Booking 30 days before
                </p>
                <p class="text-[10px] font-bold">$60 USD</p>
              </div>
            </div>

            <Button
              className="w-full bg-[#005B71] hover:bg-[#004252] text-white rounded-full text-xs h-9"
            >
              Check Availability
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
